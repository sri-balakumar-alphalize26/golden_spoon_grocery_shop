<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Dedicated paper format: full A4 but with tiny margins and no header/
         footer spacing, so short receipts fit on a single page. Same approach
         as pos_receipt_preview's paperformat. -->
    <record id="paperformat_pos_dynamic_invoice" model="report.paperformat">
        <field name="name">POS Dynamic Invoice</field>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">4</field>
        <field name="margin_bottom">4</field>
        <field name="margin_left">4</field>
        <field name="margin_right">4</field>
        <field name="header_spacing">0</field>
        <field name="header_line" eval="False"/>
        <field name="dpi">90</field>
    </record>

    <!-- Standard Odoo report so the preview embeds in Odoo and the toolbar's
         Print/Download use the normal flow. qweb-html renders the receipt as an
         embedded web page; the app fetches the same HTML via
         pos.order.get_dynamic_receipt_html(). Per-wizard render values come
         from wizard._render_context(). -->
    <record id="action_report_pos_dynamic_invoice" model="ir.actions.report">
        <field name="name">Dynamic Receipt</field>
        <field name="model">pos.dynamic.invoice.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">pos_dynamic_invoice.report_pos_dynamic_invoice</field>
        <field name="report_file">pos_dynamic_invoice.report_pos_dynamic_invoice</field>
        <field name="print_report_name">'Receipt - %s' % (object.order_id.name or object.order_id.id)</field>
        <field name="paperformat_id" ref="paperformat_pos_dynamic_invoice"/>
    </record>

    <!-- Dynamic receipt template — port of pos_receipt_preview.report_pos_receipt
         with four injection points made editable from pos.invoice.settings:
         logo, header title, VAT/GST line and footer text; plus an optional
         Terms & Conditions block. Fully self-contained — inline <style> + base64
         images only, NO external /web/assets bundles — so the mobile app can
         render/print it instantly. Rendered directly for the app via
         get_dynamic_receipt_html, and wrapped by the backend report below.
         Expects d, receipt_width, page_size_css and sig_max_h in context. -->
    <template id="report_pos_dynamic_invoice_standard_doc">
                    <div class="pos_dyn_inv_root">
                        <style>
                            @page { size: <t t-esc="page_size_css"/>; margin: 4mm; }
                            .pos_dyn_inv_root .receipt { width:<t t-esc="receipt_width"/>mm; margin:0 auto; box-sizing:border-box; font-family: Arial, Helvetica, sans-serif; color:#000; direction: rtl; padding:4mm 4mm; }
                            .pos_dyn_inv_root .rcpthead { text-align:center; font-size:11px; }
                            .pos_dyn_inv_root .rcpthead .logo { width:45%; height:auto; margin:0 auto 6px; display:block; }
                            .pos_dyn_inv_root .rcpthead .company { font-weight:700; font-size:13px; }
                            .pos_dyn_inv_root .hr { border-top:1px solid #000; margin:10px 0; }
                            .pos_dyn_inv_root .titleBox { border-top:2px solid #000; border-bottom:2px solid #000; padding:6px 0; margin:8px 0; text-align:center; font-weight:700; }
                            .pos_dyn_inv_root .meta { font-size:11px; margin-bottom:6px; }
                            .pos_dyn_inv_root table { width:100%; border-collapse:collapse; font-size:11px; }
                            .pos_dyn_inv_root th { font-weight:700; font-size:11px; padding:6px 4px; text-align:center; border-bottom:1px solid #000; }
                            .pos_dyn_inv_root td { font-size:11px; padding:6px 4px; }
                            .pos_dyn_inv_root .numCol { width:5%; }
                            .pos_dyn_inv_root .prodCol { width:40%; }
                            .pos_dyn_inv_root .qtyCol { width:10%; text-align:center; }
                            .pos_dyn_inv_root .unitCol { width:15%; text-align:right; }
                            .pos_dyn_inv_root .discCol { width:15%; text-align:right; }
                            .pos_dyn_inv_root .totalCol { width:15%; text-align:right; }
                            .pos_dyn_inv_root .divider-dotted { border-bottom:1px dotted #000; margin:8px 0; }
                            .pos_dyn_inv_root .totals { margin-top:6px; }
                            .pos_dyn_inv_root .totals .line { display:flex; justify-content:space-between; font-size:12px; padding:4px 0; }
                            .pos_dyn_inv_root .totals .label { font-weight:400; }
                            .pos_dyn_inv_root .totals .value { font-weight:700; }
                            .pos_dyn_inv_root .paymentTitle { font-weight:700; text-decoration:underline; margin-top:8px; padding-top:6px; }
                            .pos_dyn_inv_root .paymentRow { display:flex; justify-content:space-between; padding:4px 0; }
                            .pos_dyn_inv_root .termsTitle { font-weight:700; text-decoration:underline; margin-top:8px; padding-top:6px; }
                            .pos_dyn_inv_root .termsRow { font-size:10px; padding:2px 0; }
                            .pos_dyn_inv_root .rcptfoot { text-align:center; font-size:11px; margin-top:8px; white-space:pre-line; }
                        </style>
                        <div class="receipt">
                            <div class="rcpthead">
                                <t t-if="d['show_logo'] and d['logo']">
                                    <img class="logo" t-att-src="'data:image/png;base64,' + d['logo']"/>
                                </t>
                                <!-- Arabic company name (shared with the Cash Memo
                                     field) above the English name — Dynamic only;
                                     the normal-mode branch forces the flag off. -->
                                <t t-if="d.get('show_dyn_name_ar') and d['company_name_ar']">
                                    <div class="company" style="direction:rtl;"><t t-esc="d['company_name_ar']"/></div>
                                </t>
                                <div class="company"><t t-esc="d['company']['name']"/></div>
                                <t t-foreach="d['company']['address_lines']" t-as="addr_line">
                                    <div class="meta"><t t-esc="addr_line"/></div>
                                </t>
                                <t t-if="d['company']['phone']"><div class="meta"><t t-esc="d['company']['phone']"/></div></t>
                                <t t-if="d['company']['email']"><div class="meta"><t t-esc="d['company']['email']"/></div></t>
                                <!-- Dynamic-only info lines (values shared with the
                                     Cash Memo header), each behind its own settings
                                     toggle. The normal-mode branch forces the flags
                                     off, so the plain Standard receipt is unchanged. -->
                                <!-- A4 (210) / A5 (148): keep the centered lines. -->
                                <t t-if="width == 148 or width == 210">
                                    <t t-if="d.get('show_dyn_vat') and d['vat_number']"><div class="meta">VAT: <t t-esc="d['vat_number']"/></div></t>
                                    <t t-if="d.get('show_dyn_cr') and d['cr_number']"><div class="meta">C.R. No / س.ت : <t t-esc="d['cr_number']"/></div></t>
                                    <t t-if="d.get('show_dyn_gsm') and d['gsm_mobile']"><div class="meta">GSM / نقال : <t t-esc="d['gsm_mobile']"/></div></t>
                                    <t t-if="d.get('show_dyn_sultanate')"><div class="meta">Sur-Sultanate of Oman / صور-سلطنة عمان</div></t>
                                </t>
                                <!-- All other sizes: per-row mirror, English left | Arabic right. -->
                                <t t-else="">
                                    <table style="width:100%; border:1px solid #000; border-collapse:collapse; font-size:10px; margin-top:4px;">
                                        <t t-if="d.get('show_dyn_cr') and d['cr_number']">
                                            <tr>
                                                <td style="border:1px solid #000; padding:2px 6px;">C.R. No : <t t-esc="d['cr_number']"/></td>
                                                <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">السجل التجاري : <t t-esc="d['cr_number']"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="d.get('show_dyn_gsm') and d['gsm_mobile']">
                                            <tr>
                                                <td style="border:1px solid #000; padding:2px 6px;">GSM : <t t-esc="d['gsm_mobile']"/></td>
                                                <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">الهاتف : <t t-esc="d['gsm_mobile']"/></td>
                                            </tr>
                                        </t>
                                        <t t-if="d.get('show_dyn_sultanate')">
                                            <tr>
                                                <td style="border:1px solid #000; padding:2px 6px;">Sur-Sultanate of Oman</td>
                                                <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">العنوان : سلطنة عمان</td>
                                            </tr>
                                        </t>
                                        <t t-if="d.get('show_dyn_vat') and d['vat_number']">
                                            <tr>
                                                <td style="border:1px solid #000; padding:2px 6px;">VAT No : <t t-esc="d['vat_number']"/></td>
                                                <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">الرقم الضريبي : <t t-esc="d['vat_number']"/></td>
                                            </tr>
                                        </t>
                                    </table>
                                </t>
                            </div>

                            <div class="hr"></div>

                            <div class="titleBox"><t t-esc="d['header_title']"/></div>

                            <div style="display:flex; justify-content:space-between; font-size:11px; direction:ltr; margin-top:6px;">
                                <div style="text-align:left;"><t t-if="d['customer']">Customer: <t t-esc="d['customer']"/></t></div>
                                <div style="text-align:right;">Cashier: <t t-esc="d['cashier']"/></div>
                            </div>
                            <div style="display:flex; justify-content:space-between; font-size:11px; direction:ltr; margin-bottom:6px;">
                                <div style="text-align:left;">Date: <t t-esc="d['date']"/></div>
                                <div style="text-align:right;">No: <t t-esc="d['order_ref']"/></div>
                            </div>

                            <table>
                                <thead>
                                    <tr>
                                        <th class="totalCol">Total<br/><span style="font-weight:400;font-size:10px;">المجموع</span></th>
                                        <th class="discCol">Disc<br/><span style="font-weight:400;font-size:10px;">خصم</span></th>
                                        <th class="unitCol">Unit<br/><span style="font-weight:400;font-size:10px;">سعر</span></th>
                                        <th class="qtyCol">Qty<br/><span style="font-weight:400;font-size:10px;">كمية</span></th>
                                        <th class="prodCol">Product<br/><span style="font-weight:400;font-size:10px;">المنتج</span></th>
                                        <th class="numCol">#</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="d['items']" t-as="item">
                                        <tr>
                                            <td style="padding:6px 4px; text-align:right; vertical-align:top;"><span style="direction:ltr; unicode-bidi:embed;"><t t-esc="item['total_f']"/></span></td>
                                            <td style="padding:6px 4px; text-align:right; vertical-align:top;"><span style="direction:ltr; unicode-bidi:embed;"><t t-esc="item['disc_f']"/></span></td>
                                            <td style="padding:6px 4px; text-align:right; vertical-align:top;"><span style="direction:ltr; unicode-bidi:embed;"><t t-esc="item['unit_f']"/></span></td>
                                            <td style="padding:6px 4px; text-align:center; vertical-align:top;"><span style="direction:ltr; unicode-bidi:embed;"><t t-esc="item['qty']"/></span></td>
                                            <td style="padding:6px 4px; vertical-align:top;"><t t-esc="item['name']"/><div style="font-size:10px; color:#000; margin-top:4px;">KG</div><t t-if="item['note']"><div style="font-size:9px; color:#000; margin-top:2px; font-style:italic;">📝 <t t-esc="item['note']"/></div></t></td>
                                            <td style="padding:6px 4px; vertical-align:top;"><t t-esc="item['num']"/>.</td>
                                        </tr>
                                        <tr><td colspan="6" style="border-bottom:1px dotted #000; height:6px;">&#160;</td></tr>
                                    </t>
                                </tbody>
                            </table>

                            <div class="divider-dotted"></div>

                            <div class="totals">
                                <div class="line"><div class="label">Subtotal / المجموع الفرعي</div><div class="value"><t t-esc="d['subtotal_f']"/></div></div>
                                <t t-if="d['show_discount']"><div class="line"><div class="label">Discount / الخصم</div><div class="value" style="color:#000;">-<t t-esc="d['discount_f']"/></div></div></t>
                                <t t-if="d['show_tax']"><div class="line"><div class="label">Tax / الضريبة</div><div class="value"><t t-esc="d['tax_f']"/></div></div></t>
                                <div style="height:6px; border-bottom:2px solid #000; margin-top:6px;"></div>
                                <div class="line" style="font-size:13px; font-weight:700;"><div class="label">Grand Total / الإجمالي</div><div class="value"><t t-esc="d['total_f']"/></div></div>
                            </div>

                            <div style="border-top:1px solid #000; margin-top:8px; padding-top:6px;"></div>
                            <div class="paymentTitle"><t t-if="d['is_split']">Payment Details (Split) / تفاصيل الدفع</t><t t-else="">Payment Details / تفاصيل الدفع</t></div>
                            <t t-if="d['has_payments']">
                                <t t-foreach="d['payments']" t-as="pay">
                                    <div class="paymentRow"><div><t t-esc="pay['name']"/>:</div><div><t t-esc="pay['amount_f']"/></div></div>
                                </t>
                                <t t-if="d['show_change']">
                                    <div class="paymentRow"><div>Change / الباقي:</div><div><t t-esc="d['change_f']"/></div></div>
                                </t>
                            </t>
                            <t t-else="">
                                <div class="paymentRow"><div>Cash:</div><div><t t-esc="d['cash_f']"/></div></div>
                                <div class="paymentRow"><div>Change / الباقي:</div><div><t t-esc="d['cash_change_f']"/></div></div>
                            </t>

                            <t t-if="d['show_customer_sig'] or d['show_shop_owner_sig']">
                                <div style="border-top:1px solid #000; margin-top:10px; padding-top:8px; direction:ltr;">
                                    <div style="display:flex; justify-content:space-between; gap:10px;">
                                        <t t-if="d['show_customer_sig']">
                                            <div style="flex:1; text-align:center;">
                                                <img t-att-src="'data:image/png;base64,' + d['customer_signature']" t-attf-style="width:100%; height:auto; max-height:#{sig_max_h}px; object-fit:contain;"/>
                                                <div style="border-top:1px solid #000; margin-top:4px; padding-top:2px; font-size:10px;">Customer / العميل</div>
                                            </div>
                                        </t>
                                        <t t-if="d['show_shop_owner_sig']">
                                            <div style="flex:1; text-align:center;">
                                                <img t-att-src="'data:image/png;base64,' + d['shop_owner_signature']" t-attf-style="width:100%; height:auto; max-height:#{sig_max_h}px; object-fit:contain;"/>
                                                <div style="border-top:1px solid #000; margin-top:4px; padding-top:2px; font-size:10px;">Cashier / الكاشير</div>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </t>

                            <t t-if="d['show_footer']">
                                <div style="height:8px; border-bottom:1px dotted #000; margin-top:8px;"></div>
                                <div class="rcptfoot">
                                    <t t-foreach="d['footer_lines']" t-as="fline">
                                        <div><t t-esc="fline"/></div>
                                    </t>
                                </div>
                            </t>
                        </div>
                    </div>
    </template>

    <!-- Dispatcher: the app RPC and the backend wrapper both t-call
         report_pos_dynamic_invoice_doc; it picks the layout from the settings
         template (Cash Memo vs the standard branded receipt). -->
    <template id="report_pos_dynamic_invoice_doc">
        <t t-if="d['invoice_template'] == 'layout' and layout">
            <t t-call="pos_dynamic_invoice.report_pos_invoice_layout_doc"/>
        </t>
        <t t-elif="d['invoice_template'] == 'cash_memo'">
            <t t-call="pos_dynamic_invoice.report_pos_dynamic_invoice_cash_memo_doc"/>
        </t>
        <t t-else="">
            <t t-call="pos_dynamic_invoice.report_pos_dynamic_invoice_standard_doc"/>
        </t>
    </template>

    <!-- Cash Memo: bilingual (English/Arabic) Oman invoice, auto-filled from the
         order. Self-contained inline style + base64 images, no /web/assets. -->
    <template id="report_pos_dynamic_invoice_cash_memo_doc">
        <div t-attf-class="cm_root#{' narrow' if width &lt;= 110 else ''}">
            <style>
                /* Cash Memo honours the selected receipt size like the other
                   templates (page_size_css / receipt_width from the wizard), so
                   the size setting applies to all 3 templates. At thermal widths
                   the A4-style form is naturally cramped. */
                @page { size: <t t-esc="page_size_css"/>; margin: 6mm; }
                .cm_root { width:<t t-esc="receipt_width"/>mm; max-width:100%; margin:0 auto; box-sizing:border-box; font-family: Arial, Helvetica, sans-serif; color:#000; }
                /* Plain WHITE header — a filled background dithers into a dirty
                   shaded band on thermal printers. */
                .cm_root .cmhead { display:flex; justify-content:space-between; align-items:stretch; border:1px solid #000; padding:6px 10px; }
                .cm_root .cmhead .col { font-size:11px; color:#000; line-height:1.5; white-space:nowrap; }
                .cm_root .cmhead .en { text-align:left; }
                .cm_root .cmhead .ar { text-align:right; direction:rtl; }
                .cm_root .cmhead .center { text-align:center; flex:1; padding:0 10px; display:flex; flex-direction:column; justify-content:center; }
                .cm_root .cmhead .center .name-ar { font-size:20px; font-weight:700; color:#000; line-height:1.2; }
                .cm_root .cmhead .center .name-en { font-size:15px; font-weight:700; color:#000; margin-top:3px; letter-spacing:0.3px; }
                .cm_root .cmhead .logo { width:45%; height:auto; margin:0 auto 3px; display:block; }
                /* Narrow header for ALL thermal rolls (up to 110mm / 4"): the
                   3-column form can't fit a long company name on a roll, so it
                   stacks into ONE centered column — name on top, then the EN info
                   lines, then the AR info lines. Only A5/A4 (>110mm) keep the
                   3-column form. Chosen by width via t-if below (server-side). */
                .cm_root .cmhead-narrow { border:1px solid #000; padding:6px 8px; text-align:center; }
                .cm_root .cmhead-narrow .logo { width:45%; height:auto; margin:0 auto 4px; display:block; }
                .cm_root .cmhead-narrow .name-ar { font-size:16px; font-weight:700; color:#000; line-height:1.2; }
                .cm_root .cmhead-narrow .name-en { font-size:12px; font-weight:700; color:#000; margin-top:2px; }
                .cm_root .cmhead-narrow .info { font-size:12px; color:#000; line-height:1.5; margin-top:4px; white-space:normal; }
                .cm_root .cmhead-narrow .info .ar { direction:rtl; }
                /* Narrow: stack No/Date instead of side-by-side (Date was clipping). */
                .cm_root.narrow .row2 { flex-direction:column; gap:0; }
                .cm_root .cmtitle { text-align:center; font-weight:700; font-size:16px; letter-spacing:1px; margin:14px 0 12px; }
                .cm_root .field { font-size:14px; margin:9px 0; display:flex; align-items:flex-end; }
                .cm_root .field .lbl { white-space:nowrap; }
                .cm_root .field .dots { border-bottom:1px dotted #000; flex:1; margin-left:6px; min-height:16px; padding:0 4px 1px; }
                .cm_root .field .num { direction:ltr; unicode-bidi:embed; }
                .cm_root .row2 { display:flex; justify-content:space-between; gap:40px; }
                .cm_root .row2 .field { flex:1; }
                /* Auto layout (NOT table-layout:fixed) so long product names lay
                   out at natural width — the fixed layout + narrow columns crushed
                   text and smeared it when the thermal printer scaled the PDF.
                   Larger font + lighter cell borders survive that downscaling. */
                .cm_root table.items { width:100%; border-collapse:collapse; margin-top:6px; }
                /* Tight horizontal padding (was 6px) so numeric columns fit even
                   on 76/80mm rolls without the "OMR x.xxx" overflowing the right
                   border. Vertical padding kept for legibility. */
                .cm_root table.items th, .cm_root table.items td { border:1px solid #000; padding:6px 3px; font-size:13px; vertical-align:top; }
                .cm_root table.items th { text-align:center; font-weight:700; background:#fff; font-size:12px; }
                /* Arabic sub-line under each English column header (label text
                   only — no layout/size change), like the Standard receipt. */
                .cm_root table.items th .th-ar { font-weight:400; font-size:10px; }
                .cm_root table.items td.c { text-align:center; }
                /* Amounts are numeric — never wrap, force LTR so digits stay in
                   order, and give the column just enough room via a slightly
                   smaller font so "OMR 2.500" sits INSIDE its cell at any width. */
                .cm_root table.items td.r { text-align:right; white-space:nowrap; direction:ltr; unicode-bidi:embed; font-size:12px; }
                .cm_root table.items th.am { white-space:nowrap; }
                .cm_root table.items td.c { white-space:nowrap; }
                .cm_root table.items td.desc-cell { word-wrap:break-word; }
                /* Small filler so the column rules run just below the last item
                   without wasting the thermal roll (was 300px). */
                .cm_root table.items td.filler { height:24px; }
                /* Only pin the tiny Sl-No + Qty columns; let Description and the
                   numeric Amount column auto-size to their content so amounts are
                   never crushed/overflowed. */
                .cm_root .sl { width:9%; } .cm_root .qt { width:14%; }
                .cm_root .foot { display:flex; }
                .cm_root .foot .words { flex:1; border:1px solid #000; border-top:0; padding:6px; font-size:12px; }
                /* Totals box: label col auto-sizes to "Advance"; value cell gets
                   the rest with tight padding + nowrap so "OMR 8.400" always fits
                   inside the border at every paper width. */
                .cm_root .foot .totals { width:48%; }
                .cm_root .foot .totals .trow { display:flex; border:1px solid #000; border-top:0; }
                .cm_root .foot .totals .trow .k { flex:0 0 auto; white-space:nowrap; border-right:1px solid #000; padding:6px 4px; font-size:12px; font-weight:700; }
                .cm_root .foot .totals .trow .v { flex:1; min-width:0; padding:6px 4px; text-align:right; font-size:12px; white-space:nowrap; direction:ltr; unicode-bidi:embed; }
                .cm_root .sign { display:flex; justify-content:space-between; align-items:flex-end; margin-top:26px; font-size:13px; }
                .cm_root .sigcol { width:45%; text-align:center; }
                .cm_root .sigimg { max-height:48px; max-width:100%; object-fit:contain; display:block; margin:0 auto 2px; }
                .cm_root .sigline { border-top:1px solid #000; padding-top:3px; }
            </style>

            <!-- WIDE 3-column header (EN | name | AR) ONLY for the A5 (148mm) and
                 A4 (210mm) sheets. Every other size (2/3/4/8 inch, custom) uses the
                 per-row mirror header below (English left | Arabic right). -->
            <div class="cmhead" t-if="width == 148 or width == 210">
                <div class="col en">
                    <t t-if="d['show_cm_cr']"><div>C.R. No : <t t-esc="d['cr_number']"/></div></t>
                    <t t-if="d['show_cm_gsm']"><div>GSM : <t t-esc="d['gsm_mobile']"/></div></t>
                    <t t-if="d['show_cm_sultanate']"><div>Sur-Sultanate of Oman</div></t>
                    <t t-if="d['show_cm_vat']"><div>VAT No : <t t-esc="d['vat_no']"/></div></t>
                </div>
                <div class="center">
                    <t t-if="d['show_logo'] and d['logo']">
                        <img class="logo" t-att-src="'data:image/png;base64,' + d['logo']"/>
                    </t>
                    <t t-if="d['show_cm_name']">
                        <div class="name-ar"><t t-esc="d['company_name_ar']"/></div>
                        <div class="name-en"><t t-esc="d['company_name_en'] or d['company']['name']"/></div>
                    </t>
                </div>
                <div class="col ar">
                    <t t-if="d['show_cm_cr']"><div>س.ت : <t t-esc="d['cr_number']"/></div></t>
                    <t t-if="d['show_cm_gsm']"><div>نقال : <t t-esc="d['gsm_mobile']"/></div></t>
                    <t t-if="d['show_cm_sultanate']"><div>صور-سلطنة عمان</div></t>
                    <t t-if="d['show_cm_vat']"><div>الرقم الضريبي : <t t-esc="d['vat_no']"/></div></t>
                </div>
            </div>
            <!-- NARROW (<=58mm / 2"): stacked single column so nothing clips. -->
            <div class="cmhead-narrow" t-else="">
                <t t-if="d['show_logo'] and d['logo']">
                    <img class="logo" t-att-src="'data:image/png;base64,' + d['logo']"/>
                </t>
                <t t-if="d['show_cm_name']">
                    <div class="name-ar"><t t-esc="d['company_name_ar']"/></div>
                    <div class="name-en"><t t-esc="d['company_name_en'] or d['company']['name']"/></div>
                </t>
                <!-- Per-row mirror: English left | Arabic right on the same line. -->
                <table style="width:100%; border:1px solid #000; border-collapse:collapse; font-size:10px; margin-top:4px;">
                    <t t-if="d['show_cm_cr']">
                        <tr>
                            <td style="border:1px solid #000; padding:2px 6px;">C.R. No : <t t-esc="d['cr_number']"/></td>
                            <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">السجل التجاري : <t t-esc="d['cr_number']"/></td>
                        </tr>
                    </t>
                    <t t-if="d['show_cm_gsm']">
                        <tr>
                            <td style="border:1px solid #000; padding:2px 6px;">GSM : <t t-esc="d['gsm_mobile']"/></td>
                            <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">الهاتف : <t t-esc="d['gsm_mobile']"/></td>
                        </tr>
                    </t>
                    <t t-if="d['show_cm_sultanate']">
                        <tr>
                            <td style="border:1px solid #000; padding:2px 6px;">Sur-Sultanate of Oman</td>
                            <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">العنوان : سلطنة عمان</td>
                        </tr>
                    </t>
                    <t t-if="d['show_cm_vat']">
                        <tr>
                            <td style="border:1px solid #000; padding:2px 6px;">VAT No : <t t-esc="d['vat_no']"/></td>
                            <td style="border:1px solid #000; padding:2px 6px; direction:rtl; text-align:right;">الرقم الضريبي : <t t-esc="d['vat_no']"/></td>
                        </tr>
                    </t>
                </table>
            </div>

            <div class="cmtitle">INVOICE / فاتورة</div>

            <div class="row2">
                <div class="field"><span class="lbl">No / الرقم:</span><span class="dots num"><t t-esc="d['order_ref']"/></span></div>
                <div class="field"><span class="lbl">Date / التاريخ:</span><span class="dots num"><t t-esc="d['date']"/></span></div>
            </div>
            <div class="field"><span class="lbl">Name / الاسم:</span><span class="dots"><t t-esc="d['customer']"/></span></div>
            <div class="field"><span class="lbl">Address / العنوان:</span><span class="dots"><t t-esc="d['customer_address']"/></span></div>

            <table class="items">
                <thead>
                    <tr>
                        <th class="sl">Sl No<br/><span class="th-ar">م</span></th>
                        <th>Description<br/><span class="th-ar">الوصف</span></th>
                        <th class="qt">Quantity<br/><span class="th-ar">الكمية</span></th>
                        <th class="am">Amount<br/><span class="th-ar">المبلغ</span></th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="d['items']" t-as="item">
                        <tr>
                            <td class="c"><t t-esc="item['num']"/></td>
                            <td class="desc-cell"><t t-esc="item['name']"/></td>
                            <td class="c"><t t-esc="item['qty']"/></td>
                            <td class="r"><t t-esc="item['total_f']"/></td>
                        </tr>
                    </t>
                    <!-- Small filler row: runs the column rules just below the last
                         item without wasting the thermal roll. -->
                    <tr>
                        <td class="filler"></td><td></td><td></td><td></td>
                    </tr>
                </tbody>
            </table>

            <div class="foot">
                <div class="words">In Words / المبلغ كتابة: <t t-esc="d['amount_in_words']"/></div>
                <div class="totals">
                    <div class="trow"><div class="k">Total / المجموع</div><div class="v"><t t-esc="d['total_f']"/></div></div>
                    <div class="trow"><div class="k">Advance / المقدم</div><div class="v"><t t-esc="d['advance_f']"/></div></div>
                    <div class="trow"><div class="k">Due / المتبقي</div><div class="v"><t t-esc="d['due_f']"/></div></div>
                </div>
            </div>

            <div class="sign">
                <div class="sigcol">
                    <t t-if="d['show_shop_owner_sig']">
                        <img class="sigimg" t-att-src="'data:image/png;base64,' + d['shop_owner_signature']"/>
                    </t>
                    <div class="sigline">Cashier / الكاشير</div>
                </div>
                <div class="sigcol">
                    <t t-if="d['show_customer_sig']">
                        <img class="sigimg" t-att-src="'data:image/png;base64,' + d['customer_signature']"/>
                    </t>
                    <div class="sigline">Customer / العميل</div>
                </div>
            </div>
        </div>
    </template>

    <!-- Backend report: wraps the self-contained receipt body in Odoo's
         html_container + basic_layout so the in-Odoo "Preview Receipt (Dynamic)"
         and the report toolbar's Print/Download keep working (they need the
         <main> element). The mobile app does NOT use this wrapper — it would
         pull in /web/assets bundles that never load on-device and hang the
         print engine; the app renders report_pos_dynamic_invoice_doc directly. -->
    <template id="report_pos_dynamic_invoice">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-set="v" t-value="doc._render_context()"/>
                <t t-set="d" t-value="v['d']"/>
                <t t-set="width" t-value="v['width']"/>
                <t t-set="receipt_width" t-value="v['receipt_width']"/>
                <t t-set="page_size_css" t-value="v['page_size_css']"/>
                <t t-set="sig_max_h" t-value="v['sig_max_h']"/>
                <t t-set="layout" t-value="v.get('layout')"/>
                <t t-call="web.basic_layout">
                    <t t-call="pos_dynamic_invoice.report_pos_dynamic_invoice_doc"/>
                </t>
            </t>
        </t>
    </template>
</odoo>
