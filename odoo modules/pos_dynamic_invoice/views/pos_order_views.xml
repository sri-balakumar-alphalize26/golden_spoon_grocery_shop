<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add a "Preview Receipt (Dynamic)" button to the pos.order form header.
         Opens the paper-size popup, which then renders the dynamic receipt.
         Backend equivalent of the app's order-detail Preview button. -->
    <record id="view_pos_pos_form_dynamic_invoice" model="ir.ui.view">
        <field name="name">pos.order.form.dynamic.invoice</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_dynamic_receipt_preview"
                        type="object"
                        string="Preview Receipt"
                        class="btn-primary"
                        icon="fa-eye"/>
            </xpath>
        </field>
    </record>

</odoo>
