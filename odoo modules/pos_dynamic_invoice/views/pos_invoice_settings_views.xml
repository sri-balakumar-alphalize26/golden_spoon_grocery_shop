<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Settings form: the admin edits branding, logo, toggles and T&C here. -->
    <record id="pos_invoice_settings_form" model="ir.ui.view">
        <field name="name">pos.invoice.settings.form</field>
        <field name="model">pos.invoice.settings</field>
        <field name="arch" type="xml">
            <form string="Dynamic Invoice Settings">
                <header>
                    <!-- Render the selected template against a recent order.
                         Visible for ALL templates: the Standard receipt is now
                         also server-rendered (so it can carry the logo). -->
                    <button name="action_preview_receipt"
                            type="object"
                            string="Preview"
                            class="btn-primary"
                            icon="fa-eye"/>
                    <!-- Jump straight into the visual editor for the current
                         size, only when the editable Custom Layout is chosen. -->
                    <button name="action_edit_layout"
                            type="object"
                            string="Edit Layout (Drag &amp; Drop)"
                            class="btn-secondary"
                            icon="fa-object-group"
                            invisible="invoice_template != 'layout'"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="invoice_template != 'html'">
                        The app is showing the <b>standard</b> receipt (with your logo,
                        if set below). Pick <b>Dynamic</b> or <b>Cash Memo</b> above to
                        render a custom invoice.
                    </div>
                    <group>
                        <field name="company_id"/>
                        <field name="invoice_template" widget="radio" options="{'horizontal': True}"/>
                    </group>
                    <!-- Default receipt size: always visible (applies to every
                         template). The list of sizes below is fully editable —
                         add your own (e.g. "8 inch") and it appears here. -->
                    <group string="Receipt Size">
                        <field name="use_default_paper_size" widget="boolean_toggle"/>
                        <field name="default_paper_size_id" invisible="not use_default_paper_size"
                               options="{'no_create_edit': True}"/>
                        <field name="default_size_hint" invisible="not use_default_paper_size" readonly="1"/>
                    </group>
                    <!-- Paper sizes are records now: edit any width/height, or add
                         your own (e.g. "8 inch"). Change "4 inch" once and every
                         render uses your mm. Managed in a dedicated list so the
                         set can grow beyond the built-in six. -->
                    <group string="Paper Sizes">
                        <div class="text-muted" colspan="2" style="margin-bottom:8px;">
                            Add or edit receipt sizes (width, and optional fixed height, in mm).
                            Height 0 = continuous roll. These feed both the default size and the
                            print-time "choose size" popup.
                        </div>
                        <button name="action_manage_paper_sizes" type="object"
                                string="Manage Sizes" icon="fa-arrows-alt-h"
                                class="btn-secondary" colspan="2"/>
                    </group>
                    <!-- Cash Memo header (bilingual Oman invoice). -->
                    <group string="Cash Memo Header" invisible="invoice_template != 'cash_memo'">
                        <label for="company_name_en"/>
                        <div class="o_row">
                            <field name="company_name_en" nolabel="1" placeholder="Defaults to the company name"/>
                            <field name="show_cm_name" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <field name="company_name_ar"/>
                        <label for="cr_number"/>
                        <div class="o_row">
                            <field name="cr_number" nolabel="1"/>
                            <field name="show_cm_cr" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <label for="gsm"/>
                        <div class="o_row">
                            <field name="gsm" nolabel="1"/>
                            <field name="show_cm_gsm" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <field name="show_cm_sultanate" widget="boolean_toggle" string="Show Sultanate of Oman"/>
                        <label for="vat_no"/>
                        <div class="o_row">
                            <field name="vat_no" nolabel="1"/>
                            <field name="show_cm_vat" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                    </group>
                    <!-- Logo — shared by ALL templates (Standard included: the
                         Standard receipt is server-rendered and shows it too). -->
                    <group string="Logo">
                        <field name="show_logo"/>
                        <field name="logo" widget="image" class="oe_avatar" options="{'size': [160, 90]}"/>
                    </group>
                    <group string="Branding" invisible="invoice_template != 'dynamic'">
                        <field name="address" placeholder="One line per row (defaults to company address)"/>
                        <field name="phone" placeholder="Defaults to company phone"/>
                        <field name="email" placeholder="Defaults to company email"/>
                        <label for="vat_number"/>
                        <div class="o_row">
                            <field name="vat_number" nolabel="1" placeholder="VAT / GST number"/>
                            <field name="show_dyn_vat" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <!-- Header info lines shared with the Cash Memo (same
                             company_name_ar / cr_number / gsm values), each with
                             its own toggle. -->
                        <label for="company_name_ar"/>
                        <div class="o_row">
                            <field name="company_name_ar" nolabel="1"/>
                            <field name="show_dyn_name_ar" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <label for="cr_number"/>
                        <div class="o_row">
                            <field name="cr_number" nolabel="1"/>
                            <field name="show_dyn_cr" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <label for="gsm"/>
                        <div class="o_row">
                            <field name="gsm" nolabel="1"/>
                            <field name="show_dyn_gsm" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <field name="show_dyn_sultanate" widget="boolean_toggle" string="Show Sultanate of Oman"/>
                    </group>
                    <group invisible="invoice_template != 'dynamic'">
                        <group string="Header &amp; Footer">
                            <field name="header_title"/>
                            <field name="footer_text"/>
                        </group>
                        <group string="Options">
                            <field name="show_tax"/>
                            <field name="show_customer_signature"/>
                            <field name="show_shop_owner_signature"/>
                            <field name="show_footer"/>
                        </group>
                    </group>
                    <div class="alert alert-warning mt-3" role="alert">
                        <strong>General Settings — quick guide</strong>
                        <ol class="mb-1">
                            <li><b>Invoice Template</b> — pick how receipts look: <b>Standard</b> (plain), <b>Dynamic</b> / <b>Cash Memo</b> (branded), or <b>Custom Layout (editable)</b> to design your own.</li>
                            <li><b>Preview</b> (top) — see the selected template rendered against your latest order.</li>
                            <li><b>Default Receipt Size</b> — the size receipts print at (e.g. 4 inch). Add more under <b>Receipt Paper Sizes</b>.</li>
                            <li><b>Logo &amp; branding</b> — company name (EN/AR), C.R., GSM, VAT — shown on the receipt.</li>
                            <li><b>Edit Layout (Drag &amp; Drop)</b> — appears with Custom Layout; opens the visual editor (see <b>Invoice Layouts</b>).</li>
                        </ol>
                        <span class="text-muted">Full guide: <b>Invoice Settings ▸ User Manual</b>.</span>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="pos_invoice_settings_list" model="ir.ui.view">
        <field name="name">pos.invoice.settings.list</field>
        <field name="model">pos.invoice.settings</field>
        <field name="arch" type="xml">
            <list string="Dynamic Invoice Settings">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="use_dynamic_invoice" widget="boolean_toggle"/>
                <field name="vat_number"/>
                <field name="show_logo"/>
            </list>
        </field>
    </record>

    <record id="action_pos_invoice_settings" model="ir.actions.act_window">
        <field name="name">Invoice Settings</field>
        <field name="res_model">pos.invoice.settings</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure the dynamic POS invoice
            </p>
            <p>
                Set the brand name, logo, GST number, footer and terms shown on
                the POS receipt. One record per company.
            </p>
        </field>
    </record>

    <!-- Server action so the menu opens the single company settings FORM
         directly (with Preview / Edit Layout buttons), not the list. -->
    <record id="action_open_invoice_settings_form" model="ir.actions.server">
        <field name="name">Invoice Settings</field>
        <field name="model_id" ref="model_pos_invoice_settings"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_company_settings()</field>
    </record>

    <!-- "Invoice Settings" is now a PARENT heading (no action of its own) under
         the Point of Sale root, holding three children: General Settings, Receipt
         Paper Sizes, Invoice Layouts. Parented to menu_point_root (a stable xmlid
         across versions). This file loads BEFORE the paper-size and layout views
         (see manifest order) so their child menuitems can reference this parent. -->
    <menuitem id="menu_pos_invoice_settings"
              name="Invoice Settings"
              parent="point_of_sale.menu_point_root"
              sequence="90"/>

    <menuitem id="menu_pos_invoice_settings_general"
              name="General Settings"
              parent="menu_pos_invoice_settings"
              action="action_open_invoice_settings_form"
              sequence="1"/>

    <!-- In-app User Manual: opens the PDF viewer (iframe + Download). -->
    <record id="action_open_user_manual" model="ir.actions.client">
        <field name="name">User Manual</field>
        <field name="tag">pos_invoice_user_manual</field>
    </record>

    <menuitem id="menu_pos_invoice_user_manual"
              name="User Manual"
              parent="menu_pos_invoice_settings"
              action="action_open_user_manual"
              sequence="4"/>

</odoo>
