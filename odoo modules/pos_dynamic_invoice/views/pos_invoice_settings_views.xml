<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Settings form: the admin edits branding, logo, toggles and T&C here. -->
    <record id="pos_invoice_settings_form" model="ir.ui.view">
        <field name="name">pos.invoice.settings.form</field>
        <field name="model">pos.invoice.settings</field>
        <field name="arch" type="xml">
            <form string="Dynamic Invoice Settings">
                <header>
                    <!-- Render the selected template (Dynamic / Cash Memo)
                         against a recent order. Hidden for Normal (HTML), which
                         uses the app's built-in receipt. -->
                    <button name="action_preview_receipt"
                            type="object"
                            string="Preview"
                            class="btn-primary"
                            icon="fa-eye"
                            invisible="invoice_template == 'html'"/>
                </header>
                <sheet>
                    <div class="alert alert-info" role="alert" invisible="invoice_template != 'html'">
                        The app is showing its <b>standard</b> built-in receipt. Pick
                        <b>Dynamic</b> or <b>Cash Memo</b> above to render a custom invoice.
                    </div>
                    <group>
                        <field name="company_id"/>
                        <field name="invoice_template" widget="radio" options="{'horizontal': True}"/>
                    </group>
                    <!-- Default receipt size: always visible (applies to every
                         template). -->
                    <group string="Receipt Size">
                        <field name="use_default_paper_size" widget="boolean_toggle"/>
                        <field name="default_paper_size" invisible="not use_default_paper_size"/>
                        <field name="default_size_hint" invisible="not use_default_paper_size" readonly="1"/>
                        <field name="custom_paper_width" string="Custom Width (mm)" invisible="not use_default_paper_size or default_paper_size != 'custom'"
                               help="Prints as one continuous page (auto height)."/>
                    </group>
                    <!-- Editable mm for each preset (per company). Change once
                         here and every "4 inch" etc. renders at your mm. Always
                         visible: the preset mm feed both the default-size render
                         AND the print-time "choose size" popup (default OFF). -->
                    <group string="Preset Sizes (mm)">
                        <div class="text-danger" colspan="2" style="margin-bottom:8px; font-weight:500;">
                            Set each receipt size's width in mm. These apply to the default size
                            <b>and</b> the print-time "choose size" popup (shown when Use Default is off).
                            Keep each value within the allowed range shown beside it — out-of-range
                            values snap back automatically.
                        </div>
                        <label for="size_mm_2in"/>
                        <div class="o_row">
                            <field name="size_mm_2in" nolabel="1" class="oe_inline"/>
                            <span class="text-danger ms-2">allowed 40–65 mm</span>
                        </div>
                        <label for="size_mm_3in"/>
                        <div class="o_row">
                            <field name="size_mm_3in" nolabel="1" class="oe_inline"/>
                            <span class="text-danger ms-2">allowed 60–85 mm</span>
                        </div>
                        <label for="size_mm_35in"/>
                        <div class="o_row">
                            <field name="size_mm_35in" nolabel="1" class="oe_inline"/>
                            <span class="text-danger ms-2">allowed 70–95 mm</span>
                        </div>
                        <label for="size_mm_4in"/>
                        <div class="o_row">
                            <field name="size_mm_4in" nolabel="1" class="oe_inline"/>
                            <span class="text-danger ms-2">allowed 85–115 mm</span>
                        </div>
                        <label for="size_mm_a5"/>
                        <div class="o_row">
                            <field name="size_mm_a5" nolabel="1" class="oe_inline"/>
                            <span class="text-danger ms-2">allowed 140–160 mm</span>
                        </div>
                        <label for="size_mm_a4"/>
                        <div class="o_row">
                            <field name="size_mm_a4" nolabel="1" class="oe_inline"/>
                            <span class="text-danger ms-2">allowed 200–225 mm</span>
                        </div>
                        <button name="action_reset_preset_sizes" type="object"
                                string="Reset to default" icon="fa-undo" class="btn-secondary"/>
                    </group>
                    <!-- Cash Memo header (bilingual Oman invoice). -->
                    <group string="Cash Memo Header" invisible="invoice_template != 'cash_memo'">
                        <label for="company_name_en"/>
                        <div class="o_row">
                            <field name="company_name_en" nolabel="1" placeholder="Defaults to the company name"/>
                            <field name="show_cm_name" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <field name="company_name_ar"/>
                        <label for="cr_number"/>
                        <div class="o_row">
                            <field name="cr_number" nolabel="1"/>
                            <field name="show_cm_cr" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <label for="po_box"/>
                        <div class="o_row">
                            <field name="po_box" nolabel="1"/>
                            <field name="show_cm_pobox" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <label for="postal_code"/>
                        <div class="o_row">
                            <field name="postal_code" nolabel="1"/>
                            <field name="show_cm_postal" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                        <field name="show_cm_sultanate" widget="boolean_toggle" string="Show Sultanate of Oman"/>
                        <label for="gsm"/>
                        <div class="o_row">
                            <field name="gsm" nolabel="1"/>
                            <field name="show_cm_gsm" widget="boolean_toggle" nolabel="1"/><span class="ms-1 text-muted">Show</span>
                        </div>
                    </group>
                    <!-- Logo — shared by Dynamic and Cash Memo. -->
                    <group string="Logo" invisible="invoice_template == 'html'">
                        <field name="show_logo"/>
                        <field name="logo" widget="image" class="oe_avatar" options="{'size': [160, 90]}"/>
                    </group>
                    <group string="Branding" invisible="invoice_template != 'dynamic'">
                        <field name="address" placeholder="One line per row (defaults to company address)"/>
                        <field name="phone" placeholder="Defaults to company phone"/>
                        <field name="email" placeholder="Defaults to company email"/>
                        <field name="vat_number" placeholder="VAT / GST number"/>
                    </group>
                    <group invisible="invoice_template != 'dynamic'">
                        <group string="Header &amp; Footer">
                            <field name="header_title"/>
                            <field name="footer_text"/>
                        </group>
                        <group string="Options">
                            <field name="show_tax"/>
                            <field name="show_customer_signature"/>
                            <field name="show_shop_owner_signature"/>
                            <field name="show_footer"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="pos_invoice_settings_list" model="ir.ui.view">
        <field name="name">pos.invoice.settings.list</field>
        <field name="model">pos.invoice.settings</field>
        <field name="arch" type="xml">
            <list string="Dynamic Invoice Settings">
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="use_dynamic_invoice" widget="boolean_toggle"/>
                <field name="vat_number"/>
                <field name="show_logo"/>
            </list>
        </field>
    </record>

    <record id="action_pos_invoice_settings" model="ir.actions.act_window">
        <field name="name">Invoice Settings</field>
        <field name="res_model">pos.invoice.settings</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Configure the dynamic POS invoice
            </p>
            <p>
                Set the brand name, logo, GST number, footer and terms shown on
                the POS receipt. One record per company.
            </p>
        </field>
    </record>

    <!-- Menu under the Point of Sale root. Parented to menu_point_root (a
         stable xmlid across versions) rather than the Configuration submenu,
         whose id has varied between releases, so the module always installs. -->
    <menuitem id="menu_pos_invoice_settings"
              name="Invoice Settings"
              parent="point_of_sale.menu_point_root"
              action="action_pos_invoice_settings"
              sequence="90"/>

</odoo>
