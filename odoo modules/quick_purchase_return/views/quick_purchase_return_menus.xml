<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Root Menu for Quick Purchase Return App -->
    <menuitem id="quick_purchase_return_menu_root"
              name="Purchase Returns"
              sequence="46"
              web_icon="quick_purchase_return,static/description/icon.png"
              groups="purchase.group_purchase_user"/>
    
    <!-- Sub Menu - Returns -->
    <menuitem id="quick_purchase_return_menu_returns"
              name="Returns"
              parent="quick_purchase_return_menu_root"
              sequence="10"/>
    
    <!-- Action Menu Item - All Returns -->
    <menuitem id="quick_purchase_return_menu_action"
              name="Purchase Returns"
              parent="quick_purchase_return_menu_returns"
              action="quick_purchase_return_action"
              sequence="5"/>
    
    <!-- Quick New Return -->
    <menuitem id="quick_purchase_return_menu_new"
              name="New Return"
              parent="quick_purchase_return_menu_returns"
              action="quick_purchase_return_action_new"
              sequence="20"/>

    <!-- Also add to Purchase app for convenience -->
    <menuitem id="quick_purchase_return_menu_in_purchase"
              name="Quick Return"
              parent="purchase.menu_purchase_root"
              action="quick_purchase_return_action"
              sequence="6"/>

</odoo>
