<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_privilege_role_list" model="ir.ui.view">
        <field name="name">privilege.role.list</field>
        <field name="model">privilege.role</field>
        <field name="arch" type="xml">
            <list string="Groups"
                  decoration-danger="not master_create and not master_write and not master_unlink"
                  decoration-success="master_create and master_write and master_unlink">
                <field name="name"/>
                <field name="user_count" string="Users"/>
                <field name="master_read" widget="boolean_toggle" string="Read"/>
                <field name="master_create" widget="boolean_toggle" string="Create"/>
                <field name="master_write" widget="boolean_toggle" string="Edit"/>
                <field name="master_cancel" widget="boolean_toggle" string="Cancel"/>
                <field name="master_unlink" widget="boolean_toggle" string="Delete"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_privilege_role_form" model="ir.ui.view">
        <field name="name">privilege.role.form</field>
        <field name="model">privilege.role</field>
        <field name="arch" type="xml">
            <form string="Group">
                <header>
                    <button name="action_sync_groups_now"
                            string="Sync Groups to Users"
                            type="object"
                            class="btn-info"
                            title="Force re-apply all Odoo groups to users."/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Group Name"/></h1>
                    </div>
                    <group>
                        <group string="Configuration">
                            <field name="active"/>
                            <field name="company_ids" widget="many2many_tags"
                                   options="{'no_create': True}"
                                   placeholder="All Companies (leave empty for all)"/>
                        </group>
                        <group string="Group-Wide Control">
                            <field name="master_read" widget="boolean_toggle"/>
                            <field name="master_create" widget="boolean_toggle"/>
                            <field name="master_write" widget="boolean_toggle"/>
                            <field name="master_cancel" widget="boolean_toggle"/>
                            <field name="master_unlink" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>

                        <!-- Linked Odoo Groups — PRIMARY tab -->
                        <page string="Linked Odoo Groups" name="odoo_groups">
                            <div class="alert alert-success" role="alert">
                                <strong>Step 1 — Select Odoo Group(s):</strong>
                                Pick one or more existing Odoo groups (e.g. <em>Sales / User</em>,
                                <em>Inventory / Administrator</em>). Users added to this group will
                                automatically become members of these Odoo groups.<br/><br/>
                                After selecting groups, click <strong>Load Model Privileges</strong>
                                and <strong>Load Menus</strong> to auto-populate the other tabs.
                            </div>
                            <field name="odoo_group_ids" nolabel="1"
                                   options="{'no_create': True}">
                                <list>
                                    <field name="full_name" string="Odoo Group"/>
                                </list>
                            </field>
                            <div class="mt-3 d-flex gap-2">
                                <button name="action_load_from_groups"
                                        string="Load Model Privileges from Groups"
                                        type="object"
                                        class="btn-primary"
                                        icon="fa-download"
                                        title="Auto-populate Model Privileges from the selected Odoo groups' access rights"/>
                                <button name="action_load_menus_from_groups"
                                        string="Load Menus from Groups"
                                        type="object"
                                        class="btn-secondary"
                                        icon="fa-bars"
                                        title="Auto-populate Menus tab with all menus belonging to selected groups"/>
                            </div>
                        </page>

                        <!-- Model Privileges -->
                        <page string="Model Privileges" name="privileges">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="alert alert-info mb-0 flex-grow-1 me-3" role="alert">
                                    <strong>Auto-populated from Linked Odoo Groups.</strong>
                                    Select groups in the <b>Linked Odoo Groups</b> tab — privileges load automatically.
                                    You can also click <b>Reload from Groups</b> or add models manually.
                                </div>
                                <div class="d-flex gap-2">
                                    <button name="action_load_from_groups"
                                            string="Reload from Groups"
                                            type="object"
                                            class="btn-secondary"
                                            icon="fa-refresh"
                                            title="Re-load Model Privileges from the selected Odoo groups"/>
                                    <button name="action_open_add_models_wizard"
                                            string="Add Models" type="object"
                                            class="btn-primary" icon="fa-plus"/>
                                </div>
                            </div>
                            <field name="line_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="model_id"/>
                                    <field name="model_name" optional="show"/>
                                    <field name="perm_read" widget="boolean_toggle"/>
                                    <field name="perm_create" widget="boolean_toggle"/>
                                    <field name="perm_write" widget="boolean_toggle"/>
                                    <field name="perm_cancel" widget="boolean_toggle"/>
                                    <field name="perm_unlink" widget="boolean_toggle"/>
                                </list>
                            </field>
                        </page>

                        <!-- Menus -->
                        <page string="Menus" name="menu_visibility">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="alert alert-info mb-0 flex-grow-1 me-3" role="alert">
                                    <strong>Auto-populated from Linked Odoo Groups.</strong>
                                    Select groups in the <b>Linked Odoo Groups</b> tab — menus load automatically.
                                    All menus are <b>Visible = ON</b> by default.
                                    Toggle <b>OFF</b> any menu you want to <b>hide</b> from all users in this group.
                                </div>
                                <button name="action_load_menus_from_groups"
                                        string="Reload Menus"
                                        type="object"
                                        class="btn-secondary"
                                        icon="fa-refresh"
                                        title="Re-load Menus from the selected Odoo groups"/>
                            </div>
                            <field name="menu_visibility_ids" nolabel="1">
                                <list editable="bottom"
                                      decoration-danger="not is_visible"
                                      decoration-success="is_visible">
                                    <field name="menu_id"/>
                                    <field name="menu_full_name" readonly="1" string="Full Path"/>
                                    <field name="is_visible" widget="boolean_toggle" string="Visible"/>
                                </list>
                            </field>
                        </page>

                        <!-- Users -->
                        <page string="Users" name="users">
                            <div class="alert alert-info" role="alert">
                                <strong>Users added here are automatically joined to the linked Odoo group(s).</strong>
                                No extra steps needed — Odoo's native permissions apply instantly.
                            </div>
                            <field name="user_ids" nolabel="1">
                                <list>
                                    <field name="name"/>
                                    <field name="login"/>
                                    <field name="company_id"/>
                                </list>
                            </field>
                        </page>

                        <!-- Modules -->
                        <page string="Modules" name="module_visibility">
                            <div class="alert alert-info" role="alert">
                                <strong>Module Access &amp; Visibility:</strong>
                                Add app modules below. Set CRUD permissions for the module's models,
                                and toggle <b>App Visible</b> OFF to completely hide the app icon
                                from all users in this group.
                            </div>
                            <field name="module_visibility_ids" nolabel="1">
                                <list editable="bottom"
                                      decoration-danger="not is_visible"
                                      decoration-success="is_visible">
                                    <field name="module_id" options="{'no_create': True}" string="Module (App)"/>
                                    <field name="module_shortdesc" readonly="1" string="App Label"/>
                                    <field name="perm_read" widget="boolean_toggle" string="Read"/>
                                    <field name="perm_create" widget="boolean_toggle" string="Create"/>
                                    <field name="perm_write" widget="boolean_toggle" string="Edit"/>
                                    <field name="perm_cancel" widget="boolean_toggle" string="Cancel"/>
                                    <field name="perm_unlink" widget="boolean_toggle" string="Delete"/>
                                    <field name="is_visible" widget="boolean_toggle" string="App Visible"/>
                                </list>
                            </field>
                        </page>

                        <!-- Description -->
                        <page string="Description" name="description">
                            <field name="description" placeholder="Describe the purpose of this group..."/>
                        </page>

                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_privilege_role_search" model="ir.ui.view">
        <field name="name">privilege.role.search</field>
        <field name="model">privilege.role</field>
        <field name="arch" type="xml">
            <search string="Groups">
                <field name="name"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_privilege_role" model="ir.actions.act_window">
        <field name="name">Groups</field>
        <field name="res_model">privilege.role</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_active': 1}</field>
    </record>

</odoo>
