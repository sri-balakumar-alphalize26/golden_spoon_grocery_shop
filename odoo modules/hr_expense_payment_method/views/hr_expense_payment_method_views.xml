<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_expense_payment_method_form_view" model="ir.ui.view">
        <field name="name">hr.expense.payment.method.form</field>
        <field name="model">hr.expense.payment.method</field>
        <field name="arch" type="xml">
            <form string="Payment Method">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Payment Method"/>
                        <h1><field name="name" placeholder="e.g. Cash, Bank Transfer"/></h1>
                    </div>
                    <group>
                        <group string="PAYMENT CONFIGURATION">
                            <field name="journal_id" string="Payment Journal"/>
                            <field name="journal_type" invisible="1"/>
                            <field name="is_default" string="Default Payment Method"/>
                        </group>
                        <group string="SETTINGS">
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <group string="HOW IT WORKS">
                        <div class="alert alert-info" colspan="2">
                            <strong>Cash / Bank / Card / UPI Payment:</strong><br/>
                            When this method is used on an expense, the chosen journal records
                            where the payment is coming from (Cash, Bank, Card, etc.).<br/><br/>
                            <span class="text-danger"><b>NOTE:</b> Make sure the selected journal has
                            <b>Outstanding Receipts Account</b> and <b>Outstanding Payments Account</b>
                            configured in Accounting → Configuration → Journals → [Journal] → Outstanding Accounts tab.</span>
                        </div>
                    </group>
                    <field name="notes" placeholder="Internal notes about this payment method..."/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="hr_expense_payment_method_list_view" model="ir.ui.view">
        <field name="name">hr.expense.payment.method.list</field>
        <field name="model">hr.expense.payment.method</field>
        <field name="arch" type="xml">
            <list string="Payment Methods">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="journal_id" string="Payment Journal"/>
                <field name="is_default" string="Default Payment Method"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="hr_expense_payment_method_action" model="ir.actions.act_window">
        <field name="name">Payment Methods</field>
        <field name="res_model">hr.expense.payment.method</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('company_id', '=', allowed_company_ids[0])]</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
    </record>
</odoo>
