<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_easy_purchase" model="ir.sequence">
        <field name="name">Easy Purchase</field>
        <field name="code">easy.purchase</field>
        <field name="prefix">EP/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="easy_purchase_form_view" model="ir.ui.view">
        <field name="name">easy.purchase.form</field>
        <field name="model">easy.purchase</field>
        <field name="arch" type="xml">
            <form string="Easy Purchase">
                <header>
                    <button name="action_confirm" string="Confirm Purchase" type="object" class="btn-primary" invisible="state != 'draft'" confirm="This will create PO, receive stock, create bill and register payment. Continue?"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Set to Draft" type="object" invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_order" type="object" class="oe_stat_button" icon="fa-shopping-cart" invisible="not purchase_order_id">
                            <span class="o_stat_text">Purchase Order</span>
                        </button>
                        <button name="action_view_receipt" type="object" class="oe_stat_button" icon="fa-truck" invisible="not picking_id">
                            <span class="o_stat_text">Receipt</span>
                        </button>
                        <button name="action_view_bill" type="object" class="oe_stat_button" icon="fa-file-text-o" invisible="not invoice_id">
                            <span class="o_stat_text">Vendor Bill</span>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-money" invisible="not payment_ids">
                            <span class="o_stat_text">Payments</span>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Paid" bg_color="text-bg-success" invisible="payment_state != 'paid' or state != 'done'"/>
                    <widget name="web_ribbon" title="Fully Invoiced" bg_color="text-bg-info" invisible="payment_state != 'invoiced' or state != 'done'"/>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id" readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="reference" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="payment_method_id" readonly="state != 'draft'" options="{'no_create': True}"/>
                            <field name="payment_term_id" readonly="state != 'draft'" invisible="not is_credit_purchase" options="{'no_create': True}"/>
                            <field name="is_credit_purchase" invisible="1"/>
                            <field name="warehouse_id" readonly="state != 'draft'"/>
                            <field name="company_id" invisible="1"/>
                            <field name="auto_validate_bill" invisible="1"/>
                            <field name="auto_register_payment" invisible="1"/>
                        </group>
                    </group>
                    <!-- Warning: select vendor and payment method first -->
                    <div class="alert alert-warning text-center" role="alert"
                         invisible="partner_id and payment_method_id">
                        <strong>Please select a Vendor and Payment Method above to proceed.</strong>
                    </div>
                    <notebook invisible="not partner_id or not payment_method_id">
                        <page string="Products" name="products">
                            <group>
                                <field name="discount_type" widget="radio" options="{'horizontal': true}" readonly="state != 'draft'"/>
                            </group>
                            <field name="line_ids" readonly="state != 'draft'" widget="section_and_note_one2many">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_product_control" string="Add a product"/>
                                        <create name="add_section_control" string="Add a section" context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Add a note" context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    <field name="display_type" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" invisible="display_type" required="not display_type"/>
                                    <field name="name" widget="section_and_note_text"/>
                                    <field name="description" optional="hide" invisible="display_type"/>
                                    <field name="quantity" invisible="display_type"/>
                                    <field name="uom_id" groups="uom.group_uom" invisible="display_type"/>
                                    <field name="price_unit" invisible="display_type"/>
                                    <field name="discount" invisible="display_type" optional="show"/>
                                    <field name="tax_ids" widget="many2many_tags" optional="show" invisible="display_type"/>
                                    <field name="subtotal" invisible="display_type"/>
                                    <field name="total" invisible="display_type"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <button name="action_print_barcode" type="object" string="Print" title="Print Barcode Labels" invisible="display_type"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_untaxed"/>
                                <field name="amount_tax"/>
                                <field name="amount_total" class="oe_subtotal_footer_separator"/>
                            </group>
                        </page>
                        <page string="Notes" name="notes">
                            <field name="notes" placeholder="Internal notes..." readonly="state != 'draft'"/>
                        </page>
                    </notebook>
                    <group>
                        <group>
                            <field name="payment_state" widget="badge"
                                decoration-danger="payment_state == 'not_paid'"
                                decoration-success="payment_state == 'paid'"
                                decoration-info="payment_state == 'invoiced'"
                                invisible="state != 'done'"/>
                        </group>
                    </group>
                    <field name="purchase_order_id" invisible="1"/>
                    <field name="picking_id" invisible="1"/>
                    <field name="invoice_id" invisible="1"/>
                    <field name="payment_ids" invisible="1"/>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="easy_purchase_list_view" model="ir.ui.view">
        <field name="name">easy.purchase.list</field>
        <field name="model">easy.purchase</field>
        <field name="arch" type="xml">
            <list string="Easy Purchases" decoration-info="state == 'draft'" decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="reference" optional="show"/>
                <field name="payment_method_id" optional="show"/>
                <field name="amount_total" sum="Total"/>
                <field name="payment_state" widget="badge"
                    decoration-danger="payment_state == 'not_paid'"
                    decoration-success="payment_state == 'paid'"
                    decoration-info="payment_state == 'invoiced'"
                    optional="show"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-success="state == 'done'" decoration-danger="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <record id="easy_purchase_search_view" model="ir.ui.view">
        <field name="name">easy.purchase.search</field>
        <field name="model">easy.purchase</field>
        <field name="arch" type="xml">
            <search string="Search Purchases">
                <field name="name"/>
                <field name="partner_id"/>
                <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
            </search>
        </field>
    </record>

    <record id="easy_purchase_action" model="ir.actions.act_window">
        <field name="name">Easy Purchase</field>
        <field name="res_model">easy.purchase</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="easy_purchase_search_view"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create your first easy purchase</p>
        </field>
    </record>
</odoo>
