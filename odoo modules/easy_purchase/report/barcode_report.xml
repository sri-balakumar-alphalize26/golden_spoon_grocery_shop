<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_easy_purchase_barcode" model="ir.actions.report">
        <field name="name">Barcode Labels</field>
        <field name="model">easy.purchase.barcode.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">easy_purchase.report_barcode_label</field>
        <field name="report_file">easy_purchase.report_barcode_label</field>
        <field name="print_report_name">'Barcode_Labels'</field>
    </record>

    <!-- Wizard Form View -->
    <record id="easy_purchase_barcode_wizard_form" model="ir.ui.view">
        <field name="name">easy.purchase.barcode.wizard.form</field>
        <field name="model">easy.purchase.barcode.wizard</field>
        <field name="arch" type="xml">
            <form string="Print Barcode Labels">
                <group>
                    <group string="Product">
                        <field name="product_id" readonly="line_id"/>
                        <field name="line_id" invisible="1"/>
                    </group>
                    <group string="Label Settings">
                        <field name="label_size" widget="radio"/>
                        <field name="quantity"/>
                    </group>
                </group>
                <group>
                    <group string="Price Options">
                        <field name="price_type" widget="radio"/>
                    </group>
                    <group string="Prices">
                        <field name="retail_price" invisible="price_type == 'wholesale'"/>
                        <field name="wholesale_price" invisible="price_type == 'retail'"/>
                    </group>
                </group>
                <footer>
                    <button name="action_print" string="Print Labels" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <template id="report_barcode_label">
        <html>
            <head>
                <meta charset="UTF-8"/>
                <title>Barcode Labels</title>
                <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
                <style>
                    * { margin: 0; padding: 0; box-sizing: border-box; }
                    body { font-family: Arial, sans-serif; background: #f5f5f5; }

                    @media print {
                        .no-print { display: none !important; }
                        body { background: white; margin: 0; padding: 0; }
                        @page {
                            size: <t t-esc="label_dims['width']"/> <t t-esc="label_dims['height']"/>;
                            margin: 0;
                        }
                        .barcode-label {
                            page-break-after: always;
                            border: none !important;
                            margin: 0 !important;
                        }
                        .barcode-label:last-child { page-break-after: auto; }
                        .print-page { margin: 0 !important; padding: 0 !important; }
                    }

                    .print-header {
                        position: fixed; top: 0; left: 0; right: 0;
                        background: #875A7B; color: white; padding: 15px 25px;
                        display: flex; justify-content: space-between; align-items: center;
                        z-index: 1000;
                    }
                    .print-btn {
                        padding: 12px 40px; font-size: 18px; font-weight: bold;
                        background: #28a745; color: white; border: none; border-radius: 6px; cursor: pointer;
                    }
                    .print-page { margin-top: 65px; padding: 10mm; background: white; }
                    .barcode-labels { display: flex; flex-direction: column; align-items: center; gap: 2mm; }

                    .barcode-label {
                        width: <t t-esc="label_dims['width']"/>;
                        height: <t t-esc="label_dims['height']"/>;
                        border: 1px solid #ccc;
                        display: flex; flex-direction: column;
                        justify-content: space-between;
                        background: white; overflow: hidden;
                    }

                    /* ===== SIZE: 26x16mm (Small) ===== */
                    <t t-if="label_size == '26x16'">
                    .barcode-label { padding: 0.5mm 0.8mm; }
                    .shop-name { text-align: center; font-size: 4pt; font-weight: bold; line-height: 1.1; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; word-break: break-word; }
                    .product-name-bar { background: #000; color: #fff; font-size: 4pt; font-weight: bold; padding: 0.2mm 0.5mm; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.1; margin: 0 -0.8mm; }
                    .barcode-img { width: 100%; flex: 1; display: flex; align-items: center; justify-content: center; min-height: 0; }
                    .barcode-img svg { max-width: 24mm; height: 5mm; }
                    .barcode-text { font-size: 3.5pt; font-family: monospace; text-align: left; line-height: 1.0; }
                    .price-row { text-align: center; font-size: 5pt; font-weight: 900; line-height: 1.0; }
                    .price-row-small { font-size: 3.5pt; font-weight: bold; text-align: center; line-height: 1.0; }
                    .no-barcode { color: #dc3545; font-size: 5pt; }
                    </t>

                    /* ===== SIZE: 38x25mm (Medium) ===== */
                    <t t-if="label_size == '38x25'">
                    .barcode-label { padding: 1.8mm 1.2mm; }
                    .shop-name { text-align: center; font-size: 5.5pt; font-weight: bold; line-height: 1.15; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; word-break: break-word; }
                    .product-name-bar { background: #000; color: #fff; font-size: 5.5pt; font-weight: bold; padding: 0.3mm 1mm; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.2; margin: 0 -1.2mm; }
                    .barcode-img { width: 100%; flex: 1; display: flex; align-items: center; justify-content: center; min-height: 0; }
                    .barcode-img svg { max-width: 35mm; height: 8mm; }
                    .barcode-text { font-size: 5.5pt; font-family: monospace; text-align: left; line-height: 1.0; }
                    .price-row { text-align: center; font-size: 8pt; font-weight: 900; line-height: 1.1; }
                    .price-row-small { font-size: 5pt; font-weight: bold; text-align: center; line-height: 1.0; }
                    .no-barcode { color: #dc3545; font-size: 7pt; }
                    </t>

                    /* ===== SIZE: 58x39mm (Large) ===== */
                    <t t-if="label_size == '58x39'">
                    .barcode-label { padding: 2.5mm 2mm; }
                    .shop-name { text-align: center; font-size: 8pt; font-weight: bold; line-height: 1.2; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; word-break: break-word; }
                    .product-name-bar { background: #000; color: #fff; font-size: 8pt; font-weight: bold; padding: 0.5mm 1.5mm; text-align: center; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; line-height: 1.3; margin: 0 -2mm; }
                    .barcode-img { width: 100%; flex: 1; display: flex; align-items: center; justify-content: center; min-height: 0; }
                    .barcode-img svg { max-width: 54mm; height: 14mm; }
                    .barcode-text { font-size: 7pt; font-family: monospace; text-align: left; line-height: 1.0; }
                    .price-row { text-align: center; font-size: 11pt; font-weight: 900; line-height: 1.1; }
                    .price-row-small { font-size: 7pt; font-weight: bold; text-align: center; line-height: 1.0; }
                    .no-barcode { color: #dc3545; font-size: 9pt; }
                    </t>
                </style>
            </head>
            <body>
                <div class="print-header no-print">
                    <div>
                        Product: <t t-esc="products[0]['name'] if products else 'N/A'"/>
                        | Labels: <t t-esc="quantity"/>
                        | Size: <t t-esc="label_dims['width']"/> x <t t-esc="label_dims['height']"/>
                        | Price: <t t-esc="price_type"/>
                    </div>
                    <button class="print-btn" onclick="window.print();">PRINT</button>
                </div>
                <div class="print-page">
                    <div class="barcode-labels">
                        <t t-foreach="products" t-as="product">
                            <t t-foreach="range(quantity)" t-as="q">
                                <div class="barcode-label">
                                    <!-- Row 1: Shop/Company name -->
                                    <div class="shop-name"><t t-esc="company_name"/></div>

                                    <!-- Row 2: Product name with dark background -->
                                    <div class="product-name-bar"><t t-esc="product['name']"/></div>

                                    <!-- Row 3: Barcode image -->
                                    <div class="barcode-img">
                                        <t t-if="product['barcode']">
                                            <svg t-attf-id="barcode_#{product['id']}_#{q}"></svg>
                                        </t>
                                        <t t-else=""><span class="no-barcode">NO BARCODE</span></t>
                                    </div>

                                    <!-- Row 4: Barcode number -->
                                    <t t-if="product['barcode']">
                                        <div class="barcode-text"><t t-esc="product['barcode']"/></div>
                                    </t>

                                    <!-- Row 5: Price based on price_type -->
                                    <t t-if="price_type == 'retail'">
                                        <div class="price-row">
                                            <t t-esc="product['currency_name']"/>
                                            <t t-esc="'%.3f' % product['retail_price']"/>
                                            &#160;+&#160;VAT <t t-esc="'%g' % product['vat_percent']"/>%
                                        </div>
                                    </t>
                                    <t t-if="price_type == 'wholesale'">
                                        <div class="price-row">
                                            <t t-esc="product['currency_name']"/>
                                            <t t-esc="'%.3f' % product['wholesale_price']"/>
                                            &#160;+&#160;VAT <t t-esc="'%g' % product['vat_percent']"/>%
                                        </div>
                                    </t>
                                    <t t-if="price_type == 'both'">
                                        <div class="price-row">
                                            Retail: <t t-esc="product['currency_name']"/>
                                            <t t-esc="'%.3f' % product['retail_price']"/>
                                        </div>
                                        <div class="price-row-small">
                                            Wholesale: <t t-esc="product['currency_name']"/>
                                            <t t-esc="'%.3f' % product['wholesale_price']"/>
                                            &#160;+&#160;VAT <t t-esc="'%g' % product['vat_percent']"/>%
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>
                <script>
                    document.addEventListener('DOMContentLoaded', function() {
                        <t t-set="bw" t-value="'1.0'" />
                        <t t-set="bh" t-value="'20'" />
                        <t t-if="label_size == '26x16'"><t t-set="bw" t-value="'0.8'"/><t t-set="bh" t-value="'16'"/></t>
                        <t t-if="label_size == '38x25'"><t t-set="bw" t-value="'1.2'"/><t t-set="bh" t-value="'28'"/></t>
                        <t t-if="label_size == '58x39'"><t t-set="bw" t-value="'1.5'"/><t t-set="bh" t-value="'45'"/></t>
                        <t t-foreach="products" t-as="product">
                            <t t-if="product['barcode']">
                                <t t-foreach="range(quantity)" t-as="q">
                                    try { JsBarcode("#barcode_<t t-esc="product['id']"/>_<t t-esc="q"/>", "<t t-esc="product['barcode']"/>", {format:"CODE128",width:<t t-esc="bw"/>,height:<t t-esc="bh"/>,displayValue:false,margin:0}); } catch(e) {}
                                </t>
                            </t>
                        </t>
                    });
                </script>
            </body>
        </html>
    </template>
</odoo>
