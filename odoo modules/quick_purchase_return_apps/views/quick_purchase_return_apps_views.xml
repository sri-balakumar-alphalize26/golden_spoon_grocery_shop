<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Sequence for Quick Purchase Return App -->
    <record id="seq_quick_purchase_return_app" model="ir.sequence">
        <field name="name">Quick Purchase Return App</field>
        <field name="code">quick.purchase.return.app</field>
        <field name="prefix">PRA/%(year)s/</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Quick Purchase Return App Form View - POS-Style Single Screen -->
    <record id="quick_purchase_return_app_form_view" model="ir.ui.view">
        <field name="name">quick.purchase.return.app.form</field>
        <field name="model">quick.purchase.return.app</field>
        <field name="arch" type="xml">
            <form string="Purchase Return">
                <header>
                    <button name="action_confirm"
                            string="Confirm Return"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            confirm="This will create a Vendor Credit Note and Return Stock Picking. Continue?"/>
                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            invisible="state != 'draft'"/>
                    <button name="action_draft"
                            string="Set to Draft"
                            type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <!-- Smart Buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_source_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text"
                                invisible="not source_invoice_id">
                            <span class="o_stat_text">Source Bill</span>
                        </button>
                        <button name="action_view_credit_note"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="not credit_note_id">
                            <span class="o_stat_text">Credit Note</span>
                        </button>
                        <button name="action_view_return_picking"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck"
                                invisible="not return_picking_id">
                            <span class="o_stat_text">Return Picking</span>
                        </button>
                    </div>

                    <!-- Title -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>

                    <!-- Main Selection Area - Simple and Clear -->
                    <group>
                        <group string="Select Invoice">
                            <field name="source_invoice_id"
                                   readonly="state != 'draft'"
                                   options="{'no_create': True, 'no_open': True}"
                                   placeholder="Search and select a posted Vendor Bill..."/>
                            <field name="date" readonly="state != 'draft'"/>
                        </group>
                        <group string="Invoice Details">
                            <field name="partner_id" readonly="1"/>
                            <field name="invoice_date" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>

                    <!-- Quick Actions -->
                    <group invisible="state != 'draft' or not source_invoice_id">
                        <group>
                            <button name="action_return_full"
                                    string="✓ Return All"
                                    type="object"
                                    class="btn-secondary"
                                    help="Set all products to return their full returnable quantity"/>
                        </group>
                        <group>
                            <field name="warehouse_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <!-- Product Lines - Main Entry Area -->
                    <notebook>
                        <page string="Products to Return" name="products">
                            <field name="line_ids" readonly="state != 'draft'">
                                <list editable="bottom" decoration-muted="return_qty == 0">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_id" readonly="1"/>
                                    <field name="description" optional="hide" readonly="1"/>
                                    <field name="purchased_qty" readonly="1" string="Purchased"/>
                                    <field name="already_returned_qty" readonly="1" string="Returned" optional="show"/>
                                    <field name="returnable_qty" readonly="1" string="Returnable"/>
                                    <field name="return_qty" string="Return Qty"/>
                                    <field name="uom_id" readonly="1" groups="uom.group_uom"/>
                                    <field name="price_unit" readonly="1"/>
                                    <field name="discount" readonly="1" optional="hide"/>
                                    <field name="tax_ids" widget="many2many_tags" readonly="1" optional="show" column_invisible="parent.is_estimate"/>
                                    <field name="lot_id" optional="hide"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="tax_amount" readonly="1" optional="hide" column_invisible="parent.is_estimate"/>
                                    <field name="total" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                    <field name="tracking" column_invisible="1"/>
                                    <field name="source_invoice_line_id" column_invisible="1"/>
                                </list>
                            </field>

                            <!-- Totals Section -->
                            <group class="oe_subtotal_footer oe_right">
                                <field name="amount_untaxed"/>
                                <field name="amount_tax"/>
                                <div class="oe_subtotal_footer_separator oe_inline">
                                    <label for="amount_total"/>
                                </div>
                                <field name="amount_total" nolabel="1" class="oe_subtotal_footer_separator"/>
                            </group>
                            <div class="oe_clear"/>
                        </page>

                        <!-- Settings Page -->
                        <page string="Settings" name="settings">
                            <group>
                                <group string="Automation">
                                    <field name="auto_post_credit_note" readonly="state != 'draft'"/>
                                    <field name="auto_validate_picking" readonly="state != 'draft'"/>
                                </group>
                                <group string="Notes">
                                    <field name="notes" nolabel="1" placeholder="Internal notes..." readonly="state != 'draft'"/>
                                </group>
                            </group>
                            <group>
                                <field name="company_id" invisible="1"/>
                                <field name="is_estimate" invisible="1"/>
                                <field name="lines_autoloaded" invisible="1"/>
                                <field name="credit_note_id" invisible="1"/>
                                <field name="return_picking_id" invisible="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Quick Purchase Return App List View -->
    <record id="quick_purchase_return_app_list_view" model="ir.ui.view">
        <field name="name">quick.purchase.return.app.list</field>
        <field name="model">quick.purchase.return.app</field>
        <field name="arch" type="xml">
            <list string="Purchase Returns"
                  decoration-info="state == 'draft'"
                  decoration-muted="state == 'cancelled'"
                  decoration-success="state == 'done'">
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="source_invoice_id" optional="show"/>
                <field name="amount_total" sum="Total" widget="monetary"/>
                <field name="credit_note_id" optional="hide"/>
                <field name="return_picking_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="currency_id" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Quick Purchase Return App Search View -->
    <record id="quick_purchase_return_app_search_view" model="ir.ui.view">
        <field name="name">quick.purchase.return.app.search</field>
        <field name="model">quick.purchase.return.app</field>
        <field name="arch" type="xml">
            <search string="Search Purchase Returns">
                <field name="name"/>
                <field name="partner_id"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_done" string="Done" domain="[('state', '=', 'done')]"/>
                <filter name="filter_cancelled" string="Cancelled" domain="[('state', '=', 'cancelled')]"/>
            </search>
        </field>
    </record>

    <!-- Kanban View for Quick Overview -->
    <record id="quick_purchase_return_app_kanban_view" model="ir.ui.view">
        <field name="name">quick.purchase.return.app.kanban</field>
        <field name="model">quick.purchase.return.app</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="date"/>
                <field name="amount_total"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="row mb4">
                            <div class="col-6">
                                <strong><field name="name"/></strong>
                            </div>
                            <div class="col-6 text-end">
                                <field name="date"/>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-8">
                                <field name="partner_id"/>
                            </div>
                            <div class="col-4 text-end">
                                <strong><field name="amount_total" widget="monetary"/></strong>
                            </div>
                        </div>
                        <div class="row mt8">
                            <div class="col-12">
                                <field name="state" widget="label_selection"
                                       options="{'classes': {'draft': 'info', 'done': 'success', 'cancelled': 'danger'}}"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Main Action -->
    <record id="quick_purchase_return_app_action" model="ir.actions.act_window">
        <field name="name">Purchase Returns</field>
        <field name="res_model">quick.purchase.return.app</field>
        <field name="view_mode">list,form,kanban</field>
        <field name="search_view_id" ref="quick_purchase_return_app_search_view"/>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new purchase return
            </p>
            <p>
                Quick and easy purchase returns - select a vendor bill, enter return quantities, and confirm.
                <br/>
                Stock is returned and vendor credit note is created automatically.
            </p>
        </field>
    </record>

    <!-- Action for New Return (Quick Entry) -->
    <record id="quick_purchase_return_app_action_new" model="ir.actions.act_window">
        <field name="name">New Return</field>
        <field name="res_model">quick.purchase.return.app</field>
        <field name="view_mode">form</field>
        <field name="target">current</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new purchase return
            </p>
        </field>
    </record>

</odoo>
