<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Force 3 decimal places on commonly used currencies so monetary amounts
             render as e.g. 29.500 instead of 29.50. Required for GCC operations. -->
        <record id="base.OMR" model="res.currency"><field name="decimal_places">3</field></record>
        <record id="base.USD" model="res.currency"><field name="decimal_places">3</field></record>
        <record id="base.EUR" model="res.currency"><field name="decimal_places">3</field></record>
        <record id="base.GBP" model="res.currency"><field name="decimal_places">3</field></record>
        <record id="base.AED" model="res.currency"><field name="decimal_places">3</field></record>
        <record id="base.SAR" model="res.currency"><field name="decimal_places">3</field></record>
        <record id="base.QAR" model="res.currency"><field name="decimal_places">3</field></record>
    </data>
</odoo>
