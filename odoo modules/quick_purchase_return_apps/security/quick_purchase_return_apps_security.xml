<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="quick_purchase_return_app_comp_rule" model="ir.rule">
        <field name="name">Quick Purchase Return App multi-company</field>
        <field name="model_id" ref="model_quick_purchase_return_app"/>
        <field name="domain_force">['|',('company_id','=',False),('company_id','in',company_ids)]</field>
    </record>
    <record id="quick_purchase_return_line_app_comp_rule" model="ir.rule">
        <field name="name">Quick Purchase Return Line App multi-company</field>
        <field name="model_id" ref="model_quick_purchase_return_line_app"/>
        <field name="domain_force">['|',('return_id.company_id','=',False),('return_id.company_id','in',company_ids)]</field>
    </record>
</odoo>
