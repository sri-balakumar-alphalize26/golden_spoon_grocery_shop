<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== APP FEATURE CATALOG ==================== -->
    <record id="view_app_feature_list" model="ir.ui.view">
        <field name="name">app.feature.app.list</field>
        <field name="model">app.feature.app</field>
        <field name="arch" type="xml">
            <list string="Apps Privileges" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="feature_key"/>
                <field name="name"/>
                <field name="description" optional="show"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_app_feature_form" model="ir.ui.view">
        <field name="name">app.feature.app.form</field>
        <field name="model">app.feature.app</field>
        <field name="arch" type="xml">
            <form string="Apps Privilege">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Home Banner Carousel"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="feature_key" placeholder="e.g. home.banner"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <div class="alert alert-info" role="alert">
                                <strong>Feature Key</strong> must match the
                                <code>featureKey</code> prop on the corresponding
                                <code>&lt;FeatureGate&gt;</code> in the React Native app.
                                When this feature is hidden for a user (per-user or via a
                                role), the wrapped UI element will not render at all.
                            </div>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"
                               placeholder="What does this feature control in the app?"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_app_feature" model="ir.actions.act_window">
        <field name="name">Apps Privileges</field>
        <field name="res_model">app.feature.app</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define app features that can be hidden per user or per group.
            </p>
            <p>
                Each feature is identified by a <b>feature key</b> string
                (e.g. <code>home.banner</code>) that the React Native app uses
                in its <code>&lt;FeatureGate&gt;</code> wrapper. After creating a
                feature here, hide it for individual users via
                <b>Hide App Feature</b> or for whole groups via the
                <b>Apps Privileges</b> tab on a Group.
            </p>
        </field>
    </record>

    <!-- ==================== PER-USER FEATURE VISIBILITY ==================== -->
    <record id="view_app_feature_visibility_list" model="ir.ui.view">
        <field name="name">app.feature.visibility.app.list</field>
        <field name="model">app.feature.visibility.app</field>
        <field name="arch" type="xml">
            <list string="Hide App Feature" editable="bottom"
                  decoration-muted="not active">
                <field name="user_id"/>
                <field name="feature_id" options="{'no_create': True}"/>
                <field name="feature_key" optional="show"/>
                <field name="company_id" groups="base.group_multi_company" optional="hide"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_app_feature_visibility_form" model="ir.ui.view">
        <field name="name">app.feature.visibility.app.form</field>
        <field name="model">app.feature.visibility.app</field>
        <field name="arch" type="xml">
            <form string="Hide App Feature">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Target">
                            <field name="user_id" options="{'no_create': True}"/>
                            <field name="feature_id" options="{'no_create': True}"/>
                            <field name="feature_key" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   options="{'no_create': True}"/>
                            <field name="active"/>
                        </group>
                        <group string="What this hides">
                            <field name="feature_description" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                    <div class="alert alert-warning" role="alert">
                        Adding this record means the feature will be <b>hidden</b>
                        in the React Native app for the selected user. Remove the
                        record (or untick <b>Active</b>) to restore visibility.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_app_feature_visibility_search" model="ir.ui.view">
        <field name="name">app.feature.visibility.app.search</field>
        <field name="model">app.feature.visibility.app</field>
        <field name="arch" type="xml">
            <search string="Search Hidden Features">
                <field name="user_id"/>
                <field name="feature_id"/>
                <field name="feature_key"/>
                <separator/>
                <filter name="filter_active" string="Active"
                        domain="[('active', '=', True)]"/>
                <filter name="filter_archived" string="Archived"
                        domain="[('active', '=', False)]"/>
                <separator/>
                <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                <filter name="group_feature" string="Feature" context="{'group_by': 'feature_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_app_feature_visibility" model="ir.actions.act_window">
        <field name="name">Hide App Feature</field>
        <field name="res_model">app.feature.visibility.app</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_app_feature_visibility_search"/>
        <field name="context">{'search_default_filter_active': 1, 'search_default_group_user': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Hide an App Feature for a specific user
            </p>
            <p>
                Pick a <b>User</b> and an <b>App Feature</b>; the feature will
                disappear from that user's React Native app on their next login.<br/><br/>
                For group-wide hiding, edit the <b>Group</b> and use the
                <b>Apps Privileges</b> tab there.
            </p>
        </field>
    </record>

    <!-- ==================== ROLE FORM EXTENSION ==================== -->
    <record id="view_privilege_role_form_app_features" model="ir.ui.view">
        <field name="name">privilege.role.app.form.app.features</field>
        <field name="model">privilege.role.app</field>
        <field name="inherit_id" ref="view_privilege_role_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='module_visibility']" position="after">
                <page string="Apps Privileges" name="app_feature_visibility">
                    <div class="alert alert-info" role="alert">
                        <strong>Hide React Native App Features:</strong>
                        Add features below; every user in this group will have
                        the matching <code>&lt;FeatureGate&gt;</code> render as
                        nothing in the app.
                    </div>
                    <field name="app_feature_visibility_ids" nolabel="1">
                        <list editable="bottom">
                            <field name="feature_id" options="{'no_create': True}"/>
                            <field name="feature_key" readonly="1"/>
                            <field name="feature_description" readonly="1" optional="show"/>
                            <field name="active" widget="boolean_toggle"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
