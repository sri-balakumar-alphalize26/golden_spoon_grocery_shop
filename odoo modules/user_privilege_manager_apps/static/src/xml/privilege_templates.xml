п»ї<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="user_privilege_manager_apps.PrivilegeDashboard">
        <div t-att-class="'o_action' + (state.updating ? ' priv-saving' : '')" style="background:#eef1f6;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;height:100%;overflow:hidden;">
        <style>
            .priv-layout{display:flex;height:100%;overflow:hidden;}
            .priv-user-item{padding:10px 16px;cursor:pointer;transition:all 0.15s;border-left:3px solid transparent;}
            .priv-user-item:hover{background:#f0f4ff;}
            .priv-user-item.active{background:#e8edfb;border-left-color:#714b67;}
            .priv-avatar{width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:14px;color:#fff;flex-shrink:0;}
            .priv-group-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:16px;color:#fff;flex-shrink:0;}
            .priv-card{background:#fff;border-radius:10px;border:1px solid #e0e4ea;margin-bottom:14px;overflow:hidden;transition:box-shadow 0.2s;}
            .priv-card:hover{box-shadow:0 2px 12px rgba(0,0,0,0.06);}
            .priv-card-header{padding:12px 18px;display:flex;align-items:center;cursor:pointer;}
            .priv-card-title{font-weight:600;font-size:14px;color:#1e293b;}
            .priv-badge{background:#e8edfb;color:#4338ca;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:500;}
            .priv-badge-red{background:#fee2e2;color:#dc2626;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:500;}
            .priv-badge-green{background:#dcfce7;color:#16a34a;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:500;}
            .priv-badge-count{background:#714b67;color:#fff;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:500;min-width:24px;text-align:center;}
            .priv-toggle{display:inline-flex;align-items:center;gap:6px;padding:4px 0;cursor:pointer;user-select:none;font-size:13px;}
            .priv-saving .priv-toggle, .priv-saving .priv-perm-col i, .priv-saving .priv-access-chip{pointer-events:none;opacity:0.55;cursor:wait;}
            .priv-toggle-icon{font-size:20px;transition:color 0.15s;}
            .priv-toggle-on{color:#16a34a;}
            .priv-toggle-off{color:#cbd5e1;}
            .priv-toggle-label-on{font-weight:500;color:#1e293b;}
            .priv-toggle-label-off{font-weight:500;color:#94a3b8;}
            .priv-btn{font-size:11px;padding:3px 10px;border-radius:6px;border:1px solid #6b7280;color:#6b7280;background:transparent;cursor:pointer;font-weight:500;transition:all 0.15s;}
            .priv-btn:hover{background:#6b7280;color:#fff;}
            .priv-btn-green{border-color:#16a34a;color:#16a34a;}
            .priv-btn-green:hover{background:#16a34a;color:#fff;}
            .priv-btn-red{border-color:#ef4444;color:#ef4444;}
            .priv-btn-red:hover{background:#ef4444;color:#fff;}
            .priv-btn-purple{border-color:#714b67;color:#714b67;}
            .priv-btn-purple:hover{background:#714b67;color:#fff;}
            .priv-master-row{padding:10px 18px;display:flex;gap:24px;background:#f8f9fc;border-top:1px solid #e0e4ea;border-bottom:1px solid #e0e4ea;}
            .priv-table-row{display:flex;align-items:center;padding:8px 18px;border-bottom:1px solid #f1f3f5;font-size:13px;}
            .priv-table-row:last-child{border-bottom:none;}
            .priv-table-row:hover{background:#fafbfd;}
            .priv-table-header{display:flex;align-items:center;padding:8px 18px;font-size:11px;color:#6b7280;font-weight:600;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid #e0e4ea;background:#f8f9fc;}
            .priv-model-name{flex:1;min-width:0;}
            .priv-perm-col{width:70px;text-align:center;flex-shrink:0;}
            .priv-vis-col{width:90px;text-align:center;flex-shrink:0;}
            .priv-dropdown{position:absolute;left:0;top:100%;margin-top:6px;width:360px;background:#fff;border-radius:10px;border:1px solid #e0e4ea;box-shadow:0 8px 30px rgba(0,0,0,0.12);z-index:9999;overflow:hidden;}
            .priv-dropdown-item{padding:9px 16px;cursor:pointer;display:flex;align-items:center;gap:10px;font-size:13px;transition:background 0.1s;border-bottom:1px solid #f1f3f5;}
            .priv-dropdown-item:hover{background:#f0f4ff;}
            .priv-dropdown-item:last-child{border-bottom:none;}
            .priv-add-btn{padding:7px 14px;border-radius:8px;border:none;background:#714b67;color:#fff;font-size:12px;font-weight:500;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;gap:5px;}
            .priv-add-btn:hover{background:#5a3a52;}
            .priv-add-btn-sm{padding:5px 10px;border-radius:6px;border:1px solid #714b67;background:transparent;color:#714b67;font-size:11px;font-weight:500;cursor:pointer;transition:all 0.15s;}
            .priv-add-btn-sm:hover{background:#714b67;color:#fff;}
            .priv-update-btn{padding:7px 16px;border-radius:8px;border:none;background:#16a34a;color:#fff;font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:5px;box-shadow:0 2px 8px rgba(22,163,74,0.3);}
            .priv-update-btn:hover{background:#15803d;box-shadow:0 4px 12px rgba(22,163,74,0.4);}
            .priv-update-btn:disabled{background:#d1d5db;color:#9ca3af;cursor:default;box-shadow:none;opacity:0.6;}
            .priv-discard-btn{padding:7px 14px;border-radius:8px;border:1px solid #e0e4ea;background:#fff;color:#6b7280;font-size:12px;font-weight:500;cursor:pointer;transition:all 0.15s;display:flex;align-items:center;gap:5px;}
            .priv-discard-btn:hover{background:#f1f5f9;border-color:#94a3b8;}
            .priv-fullperm-btn{padding:7px 14px;border-radius:8px;border:none;background:#714b67;color:#fff;font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:5px;}
            .priv-fullperm-btn:hover{background:#5a3a52;}
            .priv-fullperm-btn:disabled{background:#d1d5db;color:#9ca3af;cursor:default;opacity:0.6;}
            .priv-reset-btn{padding:7px 14px;border-radius:8px;border:1px solid #dc2626;background:transparent;color:#dc2626;font-size:12px;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:5px;}
            .priv-reset-btn:hover{background:#dc2626;color:#fff;}
            .priv-reset-btn:disabled{border-color:#d1d5db;color:#d1d5db;cursor:default;background:transparent;opacity:0.6;}
            .priv-stat-card{text-align:center;padding:4px 12px;border-radius:8px;background:#f8f9fc;border:1px solid #e0e4ea;min-width:60px;}
            .priv-stat-num{font-size:18px;font-weight:700;line-height:1.2;}
            .priv-stat-label{font-size:9px;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;font-weight:600;}
            @keyframes priv-pulse{0%,100%{box-shadow:0 2px 8px rgba(22,163,74,0.3);}50%{box-shadow:0 2px 16px rgba(22,163,74,0.6);}}
            .priv-update-pulse{animation:priv-pulse 2s ease-in-out infinite;}
            .priv-search-input{border:1px solid #e0e4ea;border-radius:8px;padding:8px 12px;font-size:13px;width:100%;outline:none;transition:border-color 0.15s;}
            .priv-search-input:focus{border-color:#714b67;box-shadow:0 0 0 3px rgba(113,75,103,0.1);}
            .priv-tab{flex:1;padding:10px 0;text-align:center;font-weight:600;font-size:13px;cursor:pointer;transition:all 0.15s;border-bottom:2px solid transparent;color:#94a3b8;}
            .priv-tab:hover{color:#64748b;background:#f8f9fc;}
            .priv-tab.active{color:#714b67;border-bottom-color:#714b67;background:#fff;}
            .priv-section-label{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;margin-top:16px;display:flex;align-items:center;gap:6px;}
            .vis-row{display:flex;align-items:center;padding:8px 18px;border-bottom:1px solid #f1f3f5;font-size:13px;}
            .vis-row:last-child{border-bottom:none;}
            .vis-row:hover{background:#fafbfd;}
            /* Dependency card Гўв‚¬вЂќ more compact, yellow-tinted to signal "auto-added" */
            .priv-card-dep{border-color:#fde68a;background:#fffefa;margin-bottom:8px;}
            .priv-card-dep .priv-card-header{padding:8px 14px;}
            .priv-card-dep .priv-card-title{font-size:13px;color:#78350f;}
            /* Access Group checkbox chips Гўв‚¬вЂќ friendly UI for picking User/Manager/Admin tiers */
            .priv-access-group{display:inline-flex;align-items:center;gap:6px;padding:5px 12px;border-radius:16px;border:1.5px solid #cbd5e1;background:#fff;font-size:12px;font-weight:500;color:#64748b;cursor:pointer;user-select:none;transition:all 0.15s;}
            .priv-access-group:hover{border-color:#1d4ed8;color:#1e293b;}
            .priv-access-group input{cursor:pointer;accent-color:#1d4ed8;margin:0;}
            .priv-access-group-on{background:#dbeafe;border-color:#1d4ed8;color:#1e40af;font-weight:600;}
            .priv-access-group-on:hover{background:#bfdbfe;}
        </style>

        <div class="priv-layout">

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ SIDEBAR ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <div style="width:280px;min-width:280px;background:#fff;border-right:1px solid #dee2e6;display:flex;flex-direction:column;height:100%;">
            <div style="padding:14px 16px 0 16px;">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="fa fa-shield" style="color:#714b67;font-size:18px;"/>
                    <span style="font-weight:700;font-size:15px;color:#1e293b;">Privilege Manager</span>
                </div>
            </div>
            <div class="d-flex" style="border-bottom:1px solid #e0e4ea;">
                <div t-att-class="'priv-tab '+(state.activeTab==='users'?'active':'')" t-on-click="()=>this.onSwitchTab('users')">
                    <i class="fa fa-user me-1"/>Users
                </div>
                <div t-att-class="'priv-tab '+(state.activeTab==='roles'?'active':'')" t-on-click="()=>this.onSwitchTab('roles')">
                    <i class="fa fa-users me-1"/>Groups
                </div>
            </div>

            <!-- Users list -->
            <t t-if="state.activeTab==='users'">
                <div style="padding:12px 16px;">
                    <input type="text" class="priv-search-input" placeholder="Search users..." t-on-input="onSearchUser" t-att-value="state.searchUser"/>
                </div>
                <div style="overflow:auto;flex:1;">
                    <t t-foreach="filteredUsers" t-as="user" t-key="user.id">
                        <div t-att-class="'priv-user-item d-flex align-items-center gap-3 '+(state.selectedUserId===user.id?'active':'')" t-on-click="()=>this.onSelectUser(user.id)">
                            <div class="priv-avatar" t-att-style="'background:'+(state.selectedUserId===user.id?'#714b67':'#94a3b8')">
                                <span t-esc="user.name?user.name[0].toUpperCase():'?'"/>
                            </div>
                            <div style="min-width:0;">
                                <div style="font-weight:600;font-size:13px;color:#1e293b;" class="text-truncate" t-esc="user.name"/>
                                <div style="font-size:11px;color:#94a3b8;" class="text-truncate" t-esc="user.login"/>
                            </div>
                        </div>
                    </t>
                    <t t-if="filteredUsers.length===0">
                        <div style="padding:40px 20px;text-align:center;color:#94a3b8;font-size:13px;">No users found</div>
                    </t>
                </div>
            </t>

            <!-- Groups list -->
            <t t-if="state.activeTab==='roles'">
                <div style="padding:12px 16px;">
                    <input type="text" class="priv-search-input" placeholder="#Search groups..." t-on-input="onSearchRole" t-att-value="state.searchRole"/>
                </div>
                <div style="overflow:auto;flex:1;">
                    <t t-foreach="filteredRoles" t-as="role" t-key="role.id">
                        <div t-att-class="'priv-user-item d-flex align-items-center gap-3 '+(state.selectedRoleId===role.id?'active':'')" t-on-click="()=>this.onSelectRole(role.id)">
                            <div class="priv-group-icon" style="background:#714b67;"><i class="fa fa-users" style="font-size:14px;"/></div>
                            <div style="min-width:0;flex:1;">
                                <div style="font-weight:600;font-size:13px;color:#1e293b;" class="text-truncate" t-esc="role.name"/>
                                <div style="font-size:11px;color:#94a3b8;" class="text-truncate" t-esc="role.user_names_display"/>
                            </div>
                            <span class="priv-badge-count" t-esc="role.user_count||0"/>
                        </div>
                    </t>
                    <t t-if="filteredRoles.length===0">
                        <div style="padding:40px 20px;text-align:center;color:#94a3b8;font-size:13px;">No groups found</div>
                    </t>
                </div>
            </t>
        </div>

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђ MAIN CONTENT ГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <div style="flex:1;overflow:auto;background:#eef1f6;height:100%;">

            <!-- ГўвЂўВђГўвЂўВђ USERS TAB ГўвЂўВђГўвЂўВђ -->
            <t t-if="state.activeTab==='users'">

                <t t-if="!state.selectedUserId">
                    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:#94a3b8;">
                        <i class="fa fa-user" style="font-size:56px;margin-bottom:16px;opacity:0.3;"/>
                        <div style="font-size:18px;font-weight:600;color:#64748b;margin-bottom:6px;">Select a User</div>
                        <div style="font-size:13px;">Choose a user to manage their privileges</div>
                    </div>
                </t>

                <t t-if="state.selectedUserId">
                    <!-- User Header -->
                    <div style="padding:16px 28px;background:#fff;border-bottom:1px solid #e0e4ea;overflow:visible;position:relative;z-index:100;">
                        <!-- Row 1: User info + Stats -->
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="d-flex align-items-center gap-3">
                                <div class="priv-avatar" style="width:44px;height:44px;font-size:18px;background:#714b67;">
                                    <span t-esc="state.selectedUserName?state.selectedUserName[0].toUpperCase():'?'"/>
                                </div>
                                <div>
                                    <div style="font-size:17px;font-weight:700;color:#1e293b;" t-esc="state.selectedUserName"/>
                                    <div style="font-size:11px;color:#94a3b8;" t-esc="state.selectedUserLogin"/>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#714b67;" t-esc="state.userRoles.length"/>
                                    <div class="priv-stat-label">Groups</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#4338ca;" t-esc="state.modules.length"/>
                                    <div class="priv-stat-label">Modules</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#e85d00;" t-esc="state.menuPrivileges.filter(m=>!m.is_visible).length + state.specialMenuPrivileges.filter(s=>!s.is_visible).length"/>
                                    <div class="priv-stat-label">Hidden Menus</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#dc2626;" t-esc="state.moduleVisibility.filter(m=>!m.is_visible).length"/>
                                    <div class="priv-stat-label">Hidden Apps</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#9333ea;" t-esc="state.appFeatureVisibility.length"/>
                                    <div class="priv-stat-label">App Hidden Feature</div>
                                </div>
                            </div>
                        </div>
                        <!-- Row 2: Action buttons -->
                        <div class="d-flex align-items-center justify-content-between" style="padding-top:8px;border-top:1px solid #f1f3f5;overflow:visible;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="position-relative">
                                    <button class="priv-add-btn" t-on-click="toggleAddModule">
                                        <i class="fa fa-plus"/><span>Add Module</span>
                                    </button>
                                    <t t-if="state.showAddModule">
                                        <div class="priv-dropdown">
                                            <div style="padding:12px;">
                                                <input type="text" class="priv-search-input" placeholder="Search modules..." t-on-input="onModuleSearch" t-att-value="state.moduleSearch"/>
                                            </div>
                                            <div style="overflow:auto;max-height:300px;">
                                                <t t-foreach="filteredModules" t-as="mod" t-key="mod.id">
                                                    <div class="priv-dropdown-item" t-on-click="()=>this.onPickModule(mod.id)">
                                                        <i class="fa fa-cube" style="color:#714b67;"/>
                                                        <div style="min-width:0;">
                                                            <div style="font-weight:500;color:#1e293b;" class="text-truncate">
                                                                <t t-esc="mod.shortdesc||mod.name"/>
                                                                <t t-if="mod.menu_label and mod.menu_label !== (mod.shortdesc||mod.name)">
                                                                    <span style="color:#7c3aed;font-weight:400;"> (<t t-esc="mod.menu_label"/>)</span>
                                                                </t>
                                                            </div>
                                                            <div style="font-size:11px;color:#94a3b8;" t-esc="mod.name"/>
                                                        </div>
                                                    </div>
                                                </t>
                                                <t t-if="filteredModules.length===0">
                                                    <div style="padding:20px;text-align:center;color:#94a3b8;font-size:13px;">No modules available</div>
                                                </t>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <t t-if="state.isAdmin">
                                <button class="priv-fullperm-btn" t-on-click="onFullPermission" t-att-disabled="state.updating">
                                    <span>Full Permission</span>
                                </button>
                                </t>
                                <button class="priv-reset-btn" t-on-click="onResetAllPrivileges" t-att-disabled="state.updating">
                                    <i class="fa fa-eraser"/>
                                    <span>Reset All</span>
                                </button>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <button t-att-class="'priv-update-btn' + (hasPendingChanges ? ' priv-update-pulse' : '')" t-on-click="onUpdatePrivileges" t-att-disabled="!hasPendingChanges or state.updating">
                                    <span t-esc="state.updating ? 'Saving...' : 'Update'"/>
                                </button>
                                <button class="priv-discard-btn" t-on-click="onDiscardChanges" t-att-disabled="!hasPendingChanges or state.updating">
                                    <i class="fa fa-undo"/>
                                    <span>Discard</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Loading -->
                    <t t-if="state.loading">
                        <div style="text-align:center;padding:60px;color:#94a3b8;">
                            <div class="spinner-border spinner-border-sm me-2"/>Loading...
                        </div>
                    </t>

                    <div style="padding:20px 28px;" t-if="!state.loading">

                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ ADMIN BYPASS WARNING BANNER ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬
                             Shown when the selected user has base.group_system
                             or base.group_erp_manager. These groups make the
                             user an Odoo-native admin, which bypasses ALL of
                             this module's privilege rules at the framework
                             level. The toggles below will appear to work but
                             have no effect for this user. Provides a one-click
                             Clean Up button to strip manager groups. ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ -->
                        <t t-if="state.adminStatus.is_admin">
                            <div style="background:#fef2f2;border:1.5px solid #dc2626;border-radius:10px;padding:14px 18px;margin-bottom:16px;display:flex;gap:12px;align-items:flex-start;">
                                <i class="fa fa-exclamation-triangle" style="color:#dc2626;font-size:22px;margin-top:2px;flex-shrink:0;"/>
                                <div style="flex:1;min-width:0;">
                                    <div style="font-weight:700;color:#991b1b;font-size:14px;margin-bottom:4px;">
                                        This user is an administrator Гўв‚¬вЂќ privilege rules will NOT apply
                                    </div>
                                    <div style="font-size:13px;color:#7f1d1d;line-height:1.5;">
                                        <span t-esc="state.selectedUserName"/> is a member of
                                        <b t-esc="state.adminStatus.bypass_group_names.join(', ')"/>.
                                        Odoo bypasses all access control checks for administrators at the
                                        framework level, so toggles and hidden menus below will have no effect.
                                    </div>
                                    <div style="font-size:12px;color:#7f1d1d;margin-top:8px;line-height:1.5;">
                                        <b>To fix:</b>
                                        <span t-if="state.adminStatus.has_group_system">
                                            Open <b>Settings ГўвЂ вЂ™ Users &amp; Companies ГўвЂ вЂ™ <span t-esc="state.selectedUserName"/></b>,
                                            change <b>Role</b> from "Administrator" to "User", save.
                                        </span>
                                        <span t-if="state.adminStatus.has_erp_manager and !state.adminStatus.has_group_system">
                                            Uncheck the <b>Access Rights</b> permission. You can also click
                                            "Clean Up" below to remove over-granted Manager groups.
                                        </span>
                                    </div>
                                </div>
                                <div style="flex-shrink:0;">
                                    <button t-att-disabled="state.cleaningUp" style="background:#dc2626;color:#fff;border:none;border-radius:8px;padding:8px 14px;font-size:12px;font-weight:600;cursor:pointer;white-space:nowrap;" t-on-click="onCleanupAdminGroups">
                                        <i class="fa fa-eraser me-1"/>
                                        <span t-esc="state.cleaningUp ? 'Cleaning...' : 'Clean Up'"/>
                                    </button>
                                </div>
                            </div>
                        </t>

                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Group-Based Privileges ГўвЂќв‚¬ГўвЂќв‚¬ -->
                        <t t-if="state.userRoles.length>0">
                            <div class="priv-section-label" style="color:#714b67;">
                                <i class="fa fa-users"/>Group-Based Privileges
                            </div>
                            <t t-foreach="state.userRoles" t-as="ur" t-key="ur.id">
                                <div class="priv-card" style="border-left:3px solid #714b67;">
                                    <div class="priv-card-header" t-on-click="()=>this.toggleUserRoleExpand(ur.id)">
                                        <i t-att-class="'fa me-2 '+(isUserRoleExpanded(ur.id)?'fa-chevron-down':'fa-chevron-right')" style="font-size:10px;color:#94a3b8;width:14px;"/>
                                        <i class="fa fa-users me-2" style="color:#714b67;font-size:12px;"/>
                                        <span class="priv-card-title me-2" t-esc="ur.name"/>
                                        <span class="priv-badge" t-esc="(ur.lines||[]).length+' models'"/>
                                        <span style="margin-left:8px;font-size:11px;color:#94a3b8;font-style:italic;">from group</span>
                                    </div>
                                    <t t-if="isUserRoleExpanded(ur.id)">
                                        <div class="priv-table-header">
                                            <div class="priv-model-name">Model</div>
                                            <div class="priv-perm-col">Read</div><div class="priv-perm-col">Create</div>
                                            <div class="priv-perm-col">Edit</div><div class="priv-perm-col">Cancel</div><div class="priv-perm-col">Delete</div>
                                        </div>
                                        <t t-foreach="ur.lines||[]" t-as="line" t-key="line.id">
                                            <div class="priv-table-row">
                                                <div class="priv-model-name">
                                                    <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="line.model_id[1]"/>
                                                    <div style="font-size:11px;color:#94a3b8;" t-esc="line.model_name"/>
                                                </div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_read?'fa-check-circle':'fa-times-circle')" t-att-style="'font-size:16px;'+(line.perm_read?'color:#16a34a;':'color:#cbd5e1;')"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_create?'fa-check-circle':'fa-times-circle')" t-att-style="'font-size:16px;'+(line.perm_create?'color:#16a34a;':'color:#cbd5e1;')"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_write?'fa-check-circle':'fa-times-circle')" t-att-style="'font-size:16px;'+(line.perm_write?'color:#16a34a;':'color:#cbd5e1;')"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_cancel?'fa-check-circle':'fa-times-circle')" t-att-style="'font-size:16px;'+(line.perm_cancel?'color:#16a34a;':'color:#cbd5e1;')"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_unlink?'fa-check-circle':'fa-times-circle')" t-att-style="'font-size:16px;'+(line.perm_unlink?'color:#16a34a;':'color:#cbd5e1;')"/></div>
                                            </div>
                                        </t>
                                    </t>
                                </div>
                            </t>
                        </t>

                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Module-Based Privileges ГўвЂќв‚¬ГўвЂќв‚¬ -->
                        <t t-if="state.modules.length>0 and state.userRoles.length>0">
                            <div style="background:#fff7ed;border:1.5px solid #f97316;border-radius:8px;padding:12px 16px;margin-bottom:12px;display:flex;align-items:center;justify-content:space-between;gap:12px;">
                                <div style="display:flex;align-items:center;gap:10px;">
                                    <i class="fa fa-exclamation-triangle" style="color:#f97316;font-size:16px;"/>
                                    <span style="font-size:13px;color:#92400e;font-weight:600;">These module-based records are overriding your group. Click <b>Clean Up</b> to remove them and let the group take effect.</span>
                                </div>
                                <button style="background:#f97316;color:white;border:none;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:700;cursor:pointer;white-space:nowrap;" t-on-click="onCleanupModulePrivileges">
                                    <i class="fa fa-trash me-1"/>Clean Up
                                </button>
                            </div>
                        </t>
                        <div class="priv-section-label" style="color:#4338ca;">
                            <i class="fa fa-cube"/>Module-Based Privileges
                        </div>
                        <t t-if="state.modules.length===0">
                            <div class="priv-card">
                                <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                                    <i class="fa fa-cube" style="font-size:28px;opacity:0.3;display:block;margin-bottom:8px;"/>
                                    No module privileges. Click <b>+ Add Module</b> above to assign direct module-level privileges to this user.
                                </div>
                            </div>
                        </t>
                        <t t-if="state.modules.length>0">
                            <!-- ГўвЂќв‚¬ГўвЂќв‚¬ Pre-compute which modules are primary vs dependencies ГўвЂќв‚¬ГўвЂќв‚¬
                                 Primary = admin added directly; Dependency = pulled in
                                 because a primary module required it.
                                 Dep cards are visually separated and collapsed by default
                                 to reduce screen clutter (Option A from your request).   -->
                            <t t-set="primaryMods" t-value="state.modules.filter(m => !isDependencyCard(m.id))"/>
                            <t t-set="depMods" t-value="state.modules.filter(m => isDependencyCard(m.id))"/>

                            <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ PRIMARY MODULES (full card) ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                            <t t-foreach="primaryMods" t-as="mp" t-key="mp.id">
                                <t t-call="user_privilege_manager_apps.ModuleCard">
                                    <t t-set="mp" t-value="mp"/>
                                    <t t-set="isDep" t-value="false"/>
                                </t>
                            </t>

                            <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ DEPENDENCY MODULES (grouped, collapsible) ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                            <t t-if="depMods.length > 0">
                                <div style="background:#fffbeb;border:1.5px solid #fde68a;border-radius:10px;padding:10px 14px;margin-top:14px;margin-bottom:14px;">
                                    <div style="display:flex;align-items:center;gap:8px;cursor:pointer;" t-on-click="()=>this.toggleSection('depGroup')">
                                        <i t-att-class="'fa '+(isSectionCollapsed('depGroup')?'fa-chevron-right':'fa-chevron-down')" style="font-size:11px;color:#92400e;width:14px;"/>
                                        <i class="fa fa-link" style="color:#92400e;font-size:13px;"/>
                                        <span style="font-size:12px;font-weight:700;color:#92400e;text-transform:uppercase;letter-spacing:0.5px;">
                                            Dependency Modules
                                        </span>
                                        <span class="priv-badge" style="background:#fde68a;color:#92400e;margin-left:auto;" t-esc="depMods.length"/>
                                    </div>
                                    <t t-if="!isSectionCollapsed('depGroup')">
                                        <div style="margin-top:4px;font-size:11px;color:#78350f;padding-left:22px;line-height:1.5;">
                                            Added automatically to support the modules above. Click any row to customize.
                                        </div>
                                        <div style="margin-top:10px;">
                                            <t t-foreach="depMods" t-as="mp" t-key="mp.id">
                                                <t t-call="user_privilege_manager_apps.ModuleCard">
                                                    <t t-set="mp" t-value="mp"/>
                                                    <t t-set="isDep" t-value="true"/>
                                                </t>
                                            </t>
                                        </div>
                                    </t>
                                </div>
                            </t>
                        </t>

                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ HIDE MENU BUTTON Гўв‚¬вЂќ User level ГўвЂќв‚¬ГўвЂќв‚¬       -->
                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <div class="priv-section-label" style="color:#e85d00;">
                            <i class="fa fa-eye-slash"/>Hide Menu Button
                            <div class="position-relative ms-auto">
                                <button class="priv-add-btn-sm priv-add-btn" t-on-click="toggleAddMenu">
                                    <i class="fa fa-plus me-1"/>Add Menu
                                </button>
                                <t t-if="state.showAddMenu">
                                    <div class="priv-dropdown" style="left:auto;right:0;">
                                        <div style="padding:12px;">
                                            <input type="text" class="priv-search-input" placeholder="Search menus..." t-on-input="onMenuSearch" t-att-value="state.menuSearch"/>
                                        </div>
                                        <div style="overflow:auto;max-height:300px;">
                                            <t t-foreach="filteredMenusForAdd" t-as="menu" t-key="menu.id">
                                                <div class="priv-dropdown-item" t-on-click="()=>this.onPickMenu(menu.id)">
                                                    <i class="fa fa-bars" style="color:#e85d00;"/>
                                                    <div style="min-width:0;">
                                                        <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="menu.complete_name||menu.name"/>
                                                    </div>
                                                </div>
                                            </t>
                                            <t t-if="filteredMenusForAdd.length===0">
                                                <div style="padding:16px;text-align:center;font-size:12px;">
                                                    <div style="color:#64748b;font-weight:600;">No menus found</div>
                                                    <div style="color:#94a3b8;margin-top:6px;line-height:1.6;">
                                                        Try searching by exact name.<br/>
                                                        Leave empty to see all menus.<br/>
                                                        <span style="color:#7c3aed;">Tip: "Apps" menu is a root menu Гўв‚¬вЂќ<br/>try leaving the search blank and scroll.</span>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="priv-card">
                            <t t-if="state.menuPrivileges.length===0 and state.specialMenuPrivileges.length===0">
                                <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                                    <i class="fa fa-eye" style="font-size:28px;opacity:0.3;display:block;margin-bottom:8px;"/>
                                    No menu restrictions. Add a module above to see its menus here, or click <b>Add Menu</b> to hide a specific menu.
                                </div>
                            </t>
                            <!-- Special menus (Apps, Discuss, etc.) -->
                            <t t-if="state.specialMenuPrivileges.length>0">
                                <div style="font-size:11px;font-weight:700;color:#7c3aed;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('specialMenus')">
                                    <i t-att-class="'fa me-1 '+(isSectionCollapsed('specialMenus')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                    <i class="fa fa-star-o me-1"/>Special Menus
                                    <span style="background:#ede9fe;color:#7c3aed;font-size:11px;padding:2px 8px;border-radius:10px;font-weight:500;margin-left:8px;" t-esc="state.specialMenuPrivileges.length"/>
                                </div>
                                <t t-if="!isSectionCollapsed('specialMenus')">
                                <div class="priv-table-header">
                                    <div class="priv-model-name">Special Menu</div>
                                    <div class="priv-vis-col">Visible</div>
                                    <div style="width:50px;"/>
                                </div>
                                <t t-foreach="state.specialMenuPrivileges" t-as="sp" t-key="sp.id">
                                    <div class="vis-row">
                                        <div class="priv-model-name">
                                            <div style="font-weight:500;color:#7c3aed;" class="text-truncate">
                                                <i class="fa fa-star-o" style="margin-right:4px;"/>
                                                <t t-esc="sp.menu_key.charAt(0).toUpperCase() + sp.menu_key.slice(1)"/>
                                                <span style="font-size:11px;color:#94a3b8;margin-left:6px;">(client menu)</span>
                                            </div>
                                        </div>
                                        <div class="priv-vis-col">
                                            <div class="priv-toggle" t-on-click="()=>this.onSpecialMenuVisToggle(sp.id,sp.is_visible)" style="justify-content:center;">
                                                <i t-att-class="'fa priv-toggle-icon '+(sp.is_visible?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:22px;"/>
                                            </div>
                                        </div>
                                        <div style="width:50px;text-align:center;">
                                            <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveSpecialMenuPriv(sp.id)"><i class="fa fa-trash-o"/></button>
                                        </div>
                                    </div>
                                </t>
                                </t>
                            </t>
                            <t t-if="state.menuPrivileges.length>0">
                                <!-- Hidden menus (manually added or toggled off) Гўв‚¬вЂќ shown at top prominently -->
                                <t t-set="hiddenMenus" t-value="state.menuPrivileges.filter(m=>!m.is_visible)"/>
                                <t t-set="moduleMenus" t-value="state.menuPrivileges.filter(m=>m.is_visible and m.source_module_id)"/>
                                <t t-set="manualMenus" t-value="state.menuPrivileges.filter(m=>m.is_visible and !m.source_module_id)"/>

                                <!-- Hidden menus section -->
                                <t t-if="hiddenMenus.length > 0">
                                    <div style="font-size:11px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;margin-top:4px;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('hiddenMenus')">
                                        <i t-att-class="'fa me-1 '+(isSectionCollapsed('hiddenMenus')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                        <i class="fa fa-eye-slash me-1"/>Hidden Menus
                                        <span class="priv-badge-red ms-2" t-esc="hiddenMenus.length"/>
                                    </div>
                                    <t t-if="!isSectionCollapsed('hiddenMenus')">
                                    <div class="priv-table-header">
                                        <div class="priv-model-name">Menu Path</div>
                                        <div class="priv-vis-col">Visible</div>
                                        <div style="width:50px;"/>
                                    </div>
                                    <t t-foreach="hiddenMenus" t-as="mp" t-key="mp.id">
                                        <div class="vis-row" style="background:#fff5f5;border-left:3px solid #dc2626;">
                                            <div class="priv-model-name">
                                                <div style="font-weight:500;color:#dc2626;text-decoration:line-through;" class="text-truncate" t-esc="mp.menu_full_name||mp.menu_id[1]"/>
                                            </div>
                                            <div class="priv-vis-col">
                                                <div class="priv-toggle" t-on-click="()=>this.onMenuVisToggle(mp.id,mp.is_visible)" style="justify-content:center;">
                                                    <i class="fa priv-toggle-icon fa-toggle-off priv-toggle-off" style="font-size:22px;"/>
                                                </div>
                                            </div>
                                            <div style="width:50px;text-align:center;">
                                                <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveMenuPriv(mp.id)"><i class="fa fa-trash-o"/></button>
                                            </div>
                                        </div>
                                    </t>
                                    </t>
                                </t>

                                <!-- Module menus Гўв‚¬вЂќ grouped, with toggle to hide specific ones -->
                                <t t-if="moduleMenus.length > 0">
                                    <div style="font-size:11px;font-weight:700;color:#4338ca;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;margin-top:4px;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('moduleMenus')">
                                        <i t-att-class="'fa me-1 '+(isSectionCollapsed('moduleMenus')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                        <i class="fa fa-cube me-1"/>Module Menus
                                        <span class="priv-badge ms-2" t-esc="moduleMenus.length"/>
                                    </div>
                                    <t t-if="!isSectionCollapsed('moduleMenus')">
                                    <div class="priv-table-header">
                                        <div class="priv-model-name">Menu Path</div>
                                        <div class="priv-vis-col">Visible</div>
                                        <div style="width:50px;"/>
                                    </div>
                                    <t t-foreach="moduleMenus" t-as="mp" t-key="mp.id">
                                        <div class="vis-row">
                                            <div class="priv-model-name">
                                                <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="mp.menu_full_name||mp.menu_id[1]"/>
                                                <div style="font-size:10px;color:#94a3b8;" t-esc="mp.source_module_id ? mp.source_module_id[1] : ''"/>
                                            </div>
                                            <div class="priv-vis-col">
                                                <div class="priv-toggle" t-on-click="()=>this.onMenuVisToggle(mp.id,mp.is_visible)" style="justify-content:center;">
                                                    <i class="fa priv-toggle-icon fa-toggle-on priv-toggle-on" style="font-size:22px;"/>
                                                </div>
                                            </div>
                                            <div style="width:50px;text-align:center;">
                                                <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveMenuPriv(mp.id)"><i class="fa fa-trash-o"/></button>
                                            </div>
                                        </div>
                                    </t>
                                    </t>
                                </t>

                                <!-- Manually added visible menus -->
                                <t t-if="manualMenus.length > 0">
                                    <div style="font-size:11px;font-weight:700;color:#16a34a;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;margin-top:4px;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('manualMenus')">
                                        <i t-att-class="'fa me-1 '+(isSectionCollapsed('manualMenus')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                        <i class="fa fa-hand-paper-o me-1"/>Manual Menus
                                        <span class="priv-badge-green ms-2" t-esc="manualMenus.length"/>
                                    </div>
                                    <t t-if="!isSectionCollapsed('manualMenus')">
                                    <div class="priv-table-header" t-att-style="moduleMenus.length>0 ? 'margin-top:8px;' : ''">
                                        <div class="priv-model-name">Menu Path</div>
                                        <div class="priv-vis-col">Visible</div>
                                        <div style="width:50px;"/>
                                    </div>
                                    <t t-foreach="manualMenus" t-as="mp" t-key="mp.id">
                                        <div class="vis-row">
                                            <div class="priv-model-name">
                                                <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="mp.menu_full_name||mp.menu_id[1]"/>
                                            </div>
                                            <div class="priv-vis-col">
                                                <div class="priv-toggle" t-on-click="()=>this.onMenuVisToggle(mp.id,mp.is_visible)" style="justify-content:center;">
                                                    <i class="fa priv-toggle-icon fa-toggle-on priv-toggle-on" style="font-size:22px;"/>
                                                </div>
                                            </div>
                                            <div style="width:50px;text-align:center;">
                                                <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveMenuPriv(mp.id)"><i class="fa fa-trash-o"/></button>
                                            </div>
                                        </div>
                                    </t>
                                    </t>
                                </t>
                            </t>
                        </div>

