                                </div>
                            </t>
                            <t t-if="state.moduleVisibility.length>0">
                                <div style="font-size:11px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('moduleVis')">
                                    <i t-att-class="'fa me-1 '+(isSectionCollapsed('moduleVis')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                    <i class="fa fa-th me-1"/>App Icons
                                    <span class="priv-badge-red ms-2" t-esc="state.moduleVisibility.length"/>
                                </div>
                                <t t-if="!isSectionCollapsed('moduleVis')">
                                <div class="priv-table-header">
                                    <div class="priv-model-name">Application</div>
                                    <div class="priv-vis-col">App Visible</div>
                                    <div style="width:50px;"/>
                                </div>
                                <t t-foreach="state.moduleVisibility" t-as="mv" t-key="mv.id">
                                    <div class="vis-row">
                                        <div class="priv-model-name">
                                            <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="mv.module_shortdesc||mv.module_id[1]"/>
                                        </div>
                                        <div class="priv-vis-col">
                                            <div class="priv-toggle" t-on-click="()=>this.onModuleVisToggle(mv.id,mv.is_visible)" style="justify-content:center;">
                                                <i t-att-class="'fa priv-toggle-icon '+(mv.is_visible?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:22px;"/>
                                            </div>
                                        </div>
                                        <div style="width:50px;text-align:center;">
                                            <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveModuleVis(mv.id)"><i class="fa fa-trash-o"/></button>
                                        </div>
                                    </div>
                                </t>
                                </t>
                            </t>
                        </div>

                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ HIDE APP FEATURE Гўв‚¬вЂќ User level (RN app) ГўвЂќв‚¬ -->
                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <div class="priv-section-label" style="color:#0EA5E9;">
                            <i class="fa fa-mobile"/>Hide Apps Privilege
                            <div class="position-relative ms-auto">
                                <button class="priv-add-btn-sm priv-add-btn" t-on-click="toggleAddAppFeature">
                                    <i class="fa fa-plus me-1"/>Add Apps Privilege
                                </button>
                                <t t-if="state.showAddAppFeature">
                                    <div class="priv-dropdown" style="left:auto;right:0;">
                                        <div style="padding:12px;">
                                            <input type="text" class="priv-search-input" placeholder="Search apps privileges..." t-on-input="onAppFeatureSearch" t-att-value="state.appFeatureSearch"/>
                                        </div>
                                        <div style="overflow:auto;max-height:300px;">
                                            <t t-foreach="filteredAppFeaturesForAdd" t-as="feat" t-key="feat.id">
                                                <div class="priv-dropdown-item" t-on-click="()=>this.onPickAppFeature(feat.id)">
                                                    <i class="fa fa-mobile" style="color:#0EA5E9;"/>
                                                    <div style="min-width:0;">
                                                        <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="feat.name"/>
                                                        <div style="font-size:11px;color:#94a3b8;" t-esc="feat.feature_key"/>
                                                    </div>
                                                </div>
                                            </t>
                                            <t t-if="filteredAppFeaturesForAdd.length===0">
                                                <div style="padding:20px;text-align:center;color:#94a3b8;font-size:13px;">No apps privileges available</div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <div class="priv-card">
                            <t t-if="state.appFeatureVisibility.length===0">
                                <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                                    <i class="fa fa-mobile" style="font-size:28px;opacity:0.3;display:block;margin-bottom:8px;"/>
                                    All apps privileges visible. Click <b>Add Apps Privilege</b> to hide specific React Native app elements for this user.
                                </div>
                            </t>
                            <t t-if="state.appFeatureVisibility.length>0">
                                <div class="priv-table-header">
                                    <div class="priv-model-name">Apps Privilege</div>
                                    <div class="priv-vis-col" style="text-align:center;">Feature Key</div>
                                    <div style="width:50px;"/>
                                </div>
                                <t t-foreach="state.appFeatureVisibility" t-as="afv" t-key="afv.id">
                                    <div class="vis-row">
                                        <div class="priv-model-name">
                                            <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="afv.feature_id[1]"/>
                                        </div>
                                        <div class="priv-vis-col" style="font-size:11px;color:#94a3b8;text-align:center;" t-esc="afv.feature_key"/>
                                        <div style="width:50px;text-align:center;">
                                            <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveAppFeature(afv.id)"><i class="fa fa-trash-o"/></button>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>

                    </div><!-- /padding -->
                </t>
            </t><!-- /users tab -->

            <!-- ГўвЂўВђГўвЂўВђ GROUPS TAB ГўвЂўВђГўвЂўВђ -->
            <t t-if="state.activeTab==='roles'">
                <t t-if="!state.selectedRoleId">
                    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;height:100%;color:#94a3b8;">
                        <i class="fa fa-users" style="font-size:56px;margin-bottom:16px;opacity:0.3;"/>
                        <div style="font-size:18px;font-weight:600;color:#64748b;margin-bottom:6px;">Select a Group</div>
                        <div style="font-size:13px;">Choose a group from the sidebar</div>
                    </div>
                </t>

                <t t-if="state.selectedRoleId">
                    <!-- Group Header -->
                    <div style="padding:16px 28px;background:#fff;border-bottom:1px solid #e0e4ea;">
                        <!-- Row 1: Group info + Stats -->
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div class="d-flex align-items-center gap-3">
                                <div class="priv-group-icon" style="width:44px;height:44px;font-size:18px;background:#714b67;border-radius:12px;">
                                    <i class="fa fa-users"/>
                                </div>
                                <div>
                                    <div style="font-size:17px;font-weight:700;color:#1e293b;" t-esc="state.selectedRoleName"/>
                                    <div style="font-size:11px;color:#94a3b8;">Group Privileges</div>
                                </div>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#714b67;" t-esc="totalRoleModuleCount"/>
                                    <div class="priv-stat-label">Modules</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#4338ca;" t-esc="totalRoleModels"/>
                                    <div class="priv-stat-label">Models</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#e85d00;" t-esc="state.roleMenuVisibility.filter(m=>!m.is_visible).length"/>
                                    <div class="priv-stat-label">Hidden Menus</div>
                                </div>
                                <div class="priv-stat-card">
                                    <div class="priv-stat-num" style="color:#dc2626;" t-esc="state.roleModuleVisibility.filter(m=>!m.is_visible).length"/>
                                    <div class="priv-stat-label">Hidden Apps</div>
                                </div>
                            </div>
                        </div>
                        <!-- Row 2: Action buttons -->
                        <div class="d-flex align-items-center justify-content-between" style="padding-top:8px;border-top:1px solid #f1f3f5;overflow:visible;">
                            <div class="d-flex align-items-center gap-2">
                                <div class="position-relative">
                                    <button class="priv-add-btn" t-on-click="toggleAddRoleModulePriv">
                                        <i class="fa fa-plus"/><span>Add Module</span>
                                    </button>
                                    <t t-if="state.showAddRoleModulePriv">
                                        <div class="priv-dropdown">
                                            <div style="padding:12px;">
                                                <input type="text" class="priv-search-input" placeholder="Search modules..." t-on-input="onRoleModulePrivSearch" t-att-value="state.roleModulePrivSearch"/>
                                            </div>
                                            <div style="overflow:auto;max-height:300px;">
                                                <t t-foreach="filteredModulesForRolePrivAdd" t-as="mod" t-key="mod.id">
                                                    <div class="priv-dropdown-item" t-on-click="()=>this.onPickRoleModulePriv(mod.id)">
                                                        <i class="fa fa-cube" style="color:#714b67;"/>
                                                        <div style="min-width:0;">
                                                            <div style="font-weight:500;color:#1e293b;" class="text-truncate">
                                                                <t t-esc="mod.shortdesc||mod.name"/>
                                                                <t t-if="mod.menu_label and mod.menu_label !== (mod.shortdesc||mod.name)">
                                                                    <span style="color:#7c3aed;font-weight:400;"> (<t t-esc="mod.menu_label"/>)</span>
                                                                </t>
                                                            </div>
                                                            <div style="font-size:11px;color:#94a3b8;" t-esc="mod.name"/>
                                                        </div>
                                                    </div>
                                                </t>
                                                <t t-if="filteredModulesForRolePrivAdd.length===0">
                                                    <div style="padding:20px;text-align:center;color:#94a3b8;font-size:13px;">No modules available</div>
                                                </t>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                                <button class="priv-btn priv-btn-green" t-on-click="onRoleGrantAll"><i class="fa fa-check me-1"/>Grant All</button>
                                <button class="priv-btn" t-on-click="onRoleRevokeAll">Read Only</button>
                                <button class="priv-reset-btn" t-on-click="onResetRolePrivileges" t-att-disabled="state.updating or (state.roleMenuVisibility.length === 0 and state.roleModuleVisibility.length === 0)">
                                    <i class="fa fa-eraser"/>
                                    <span>Reset All</span>
                                </button>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <button t-att-class="'priv-update-btn' + (hasPendingChanges ? ' priv-update-pulse' : '')" t-on-click="onUpdatePrivileges" t-att-disabled="!hasPendingChanges or state.updating">
                                    <span t-esc="state.updating ? 'Saving...' : 'Update'"/>
                                </button>
                                <button class="priv-discard-btn" t-on-click="onDiscardChanges" t-att-disabled="!hasPendingChanges or state.updating">
                                    <i class="fa fa-undo"/>
                                    <span>Discard</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <t t-if="state.roleLoading">
                        <div style="text-align:center;padding:60px;color:#94a3b8;">
                            <div class="spinner-border spinner-border-sm me-2"/>Loading...
                        </div>
                    </t>

                    <div style="padding:20px 28px;" t-if="!state.roleLoading">

                        <!-- Group Module-Based Privileges -->
                        <div class="priv-section-label" style="color:#4338ca;">
                            <i class="fa fa-cube"/>Module-Based Privileges
                        </div>
                        <t t-if="state.roleModulePrivileges.length===0">
                            <div class="priv-card">
                                <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                                    <i class="fa fa-cube" style="font-size:28px;opacity:0.3;display:block;margin-bottom:8px;"/>
                                    No module privileges. Click <b>+ Add Module</b> above to assign module-level privileges to this group.
                                </div>
                            </div>
                        </t>
                        <t t-if="state.roleModulePrivileges.length>0">
                            <t t-foreach="state.roleModulePrivileges" t-as="rmod" t-key="rmod.module_id">
