                                <button class="priv-add-btn-sm priv-add-btn" t-on-click="toggleAddModuleVis">
                                    <i class="fa fa-plus me-1"/>Add App
                                </button>
                                <t t-if="state.showAddModuleVis">
                                    <div class="priv-dropdown" style="left:auto;right:0;">
                                        <div style="padding:12px;">
                                            <input type="text" class="priv-search-input" placeholder="Search apps..." t-on-input="onModuleVisSearch" t-att-value="state.moduleVisSearch"/>
                                        </div>
                                        <div style="overflow:auto;max-height:300px;">
                                            <t t-foreach="filteredModulesForVisAdd" t-as="mod" t-key="mod.id">
