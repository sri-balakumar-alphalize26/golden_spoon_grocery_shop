                                        </div>
                                    </div>
                                    <t t-if="isRoleModuleExpanded(rmod.module_id)">
                                        <div class="priv-table-header">
                                            <div class="priv-model-name">Model</div>
                                            <div class="priv-perm-col">Read</div><div class="priv-perm-col">Create</div>
                                            <div class="priv-perm-col">Edit</div><div class="priv-perm-col">Cancel</div><div class="priv-perm-col">Delete</div>
                                        </div>
                                        <t t-foreach="rmod.lines" t-as="line" t-key="line.id">
                                            <div class="priv-table-row">
                                                <div class="priv-model-name">
                                                    <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="line.model_id[1]"/>
                                                    <div style="font-size:11px;color:#94a3b8;" t-esc="line.model_name"/>
                                                </div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_read?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onRoleLineToggle(line.id,'perm_read',line.perm_read)"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_create?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onRoleLineToggle(line.id,'perm_create',line.perm_create)"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_write?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onRoleLineToggle(line.id,'perm_write',line.perm_write)"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_cancel?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onRoleLineToggle(line.id,'perm_cancel',line.perm_cancel)"/></div>
                                                <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_unlink?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onRoleLineToggle(line.id,'perm_unlink',line.perm_unlink)"/></div>
                                            </div>
                                        </t>
                                    </t>
                                </div>
                            </t>
                        </t>

                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ GROUP: HIDE MENU BUTTON ГўвЂќв‚¬ГўвЂќв‚¬             -->
                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <div class="priv-section-label" style="color:#e85d00;">
                            <i class="fa fa-eye-slash"/>Hide Menu Button (Group)
                            <div class="position-relative ms-auto">
                                <button class="priv-add-btn-sm priv-add-btn" t-on-click="toggleAddRoleMenu">
                                    <i class="fa fa-plus me-1"/>Add Menu
                                </button>
                                <t t-if="state.showAddRoleMenu">
                                    <div class="priv-dropdown" style="left:auto;right:0;">
                                        <div style="padding:12px;">
                                            <input type="text" class="priv-search-input" placeholder="Search menus..." t-on-input="onRoleMenuSearch" t-att-value="state.roleMenuSearch"/>
                                        </div>
                                        <div style="overflow:auto;max-height:300px;">
                                            <t t-foreach="filteredMenusForRoleAdd" t-as="menu" t-key="menu.id">
                                                <div class="priv-dropdown-item" t-on-click="()=>this.onPickRoleMenu(menu.id)">
                                                    <i class="fa fa-bars" style="color:#e85d00;"/>
                                                    <div style="min-width:0;">
                                                        <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="menu.complete_name||menu.name"/>
                                                    </div>
                                                </div>
                                            </t>
                                            <t t-if="filteredMenusForRoleAdd.length===0">
                                                <div style="padding:20px;text-align:center;color:#94a3b8;font-size:13px;">No menus found</div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="priv-card">
                            <t t-if="state.roleMenuVisibility.length===0">
                                <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                                    <i class="fa fa-eye" style="font-size:28px;opacity:0.3;display:block;margin-bottom:8px;"/>
                                    No menu restrictions for this group. Click <b>Add Menu</b> to hide menus for all group members.
                                </div>
                            </t>
                            <t t-if="state.roleMenuVisibility.length>0">
                                <!-- Hidden menus section (red, shown first) -->
                                <t t-set="hiddenRoleMenus" t-value="state.roleMenuVisibility.filter(m=>!m.is_visible)"/>
                                <t t-if="hiddenRoleMenus.length > 0">
                                    <div style="font-size:11px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('roleHiddenMenus')">
                                        <i t-att-class="'fa me-1 '+(isSectionCollapsed('roleHiddenMenus')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                        <i class="fa fa-eye-slash me-1"/>Hidden Menus
                                        <span class="priv-badge-red ms-2" t-esc="hiddenRoleMenus.length"/>
                                    </div>
                                    <t t-if="!isSectionCollapsed('roleHiddenMenus')">
                                    <div class="priv-table-header">
                                        <div class="priv-model-name">Menu Path</div>
                                        <div class="priv-vis-col">Visible</div>
                                        <div style="width:50px;"/>
                                    </div>
                                    <t t-foreach="hiddenRoleMenus" t-as="rm" t-key="rm.id">
                                        <div class="vis-row">
                                            <div class="priv-model-name">
                                                <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="rm.menu_full_name||rm.menu_id[1]"/>
                                            </div>
                                            <div class="priv-vis-col">
                                                <div class="priv-toggle" t-on-click="()=>this.onRoleMenuVisToggle(rm.id,rm.is_visible)" style="justify-content:center;">
                                                    <i t-att-class="'fa priv-toggle-icon '+(rm.is_visible?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:22px;"/>
                                                </div>
                                            </div>
                                            <div style="width:50px;text-align:center;">
                                                <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveRoleMenu(rm.id)"><i class="fa fa-trash-o"/></button>
                                            </div>
                                        </div>
                                    </t>
                                    </t>
                                </t>
                                <!-- All menus section (toggle on/off) -->
                                <div style="font-size:11px;font-weight:700;color:#e85d00;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('roleMenus')">
                                    <i t-att-class="'fa me-1 '+(isSectionCollapsed('roleMenus')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                    <i class="fa fa-bars me-1"/>All Menus
                                    <span class="priv-badge ms-2" t-esc="state.roleMenuVisibility.length"/>
                                </div>
                                <t t-if="!isSectionCollapsed('roleMenus')">
                                <div class="priv-table-header">
                                    <div class="priv-model-name">Menu Path</div>
                                    <div class="priv-vis-col">Visible</div>
                                    <div style="width:50px;"/>
                                </div>
                                <t t-foreach="state.roleMenuVisibility" t-as="rm" t-key="rm.id">
                                    <div class="vis-row">
                                        <div class="priv-model-name">
                                            <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="rm.menu_full_name||rm.menu_id[1]"/>
                                        </div>
                                        <div class="priv-vis-col">
                                            <div class="priv-toggle" t-on-click="()=>this.onRoleMenuVisToggle(rm.id,rm.is_visible)" style="justify-content:center;">
                                                <i t-att-class="'fa priv-toggle-icon '+(rm.is_visible?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:22px;"/>
                                            </div>
                                        </div>
                                        <div style="width:50px;text-align:center;">
                                            <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveRoleMenu(rm.id)"><i class="fa fa-trash-o"/></button>
                                        </div>
                                    </div>
                                </t>
                                </t>
                            </t>
                        </div>

                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <!-- ГўвЂќв‚¬ГўвЂќв‚¬ GROUP: HIDE MODULE BUTTON ГўвЂќв‚¬ГўвЂќв‚¬           -->
                        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
                        <div class="priv-section-label" style="color:#dc2626;">
                            <i class="fa fa-th"/>Hide Module Button / App Icon (Group)
                            <div class="position-relative ms-auto">
                                <button class="priv-add-btn-sm priv-add-btn" t-on-click="toggleAddRoleModule">
                                    <i class="fa fa-plus me-1"/>Add App
                                </button>
                                <t t-if="state.showAddRoleModule">
                                    <div class="priv-dropdown" style="left:auto;right:0;">
                                        <div style="padding:12px;">
                                            <input type="text" class="priv-search-input" placeholder="Search apps..." t-on-input="onRoleModuleSearch" t-att-value="state.roleModuleSearch"/>
                                        </div>
                                        <div style="overflow:auto;max-height:300px;">
                                            <t t-foreach="filteredModulesForRoleVisAdd" t-as="mod" t-key="mod.id">
                                                <div class="priv-dropdown-item" t-on-click="()=>this.onPickRoleModule(mod.id)">
                                                    <i class="fa fa-th" style="color:#dc2626;"/>
                                                    <div style="min-width:0;">
                                                        <div style="font-weight:500;color:#1e293b;" class="text-truncate">
                                                            <t t-esc="mod.shortdesc||mod.name"/>
                                                            <t t-if="mod.menu_label and mod.menu_label !== (mod.shortdesc||mod.name)">
                                                                <span style="color:#7c3aed;font-weight:400;"> (<t t-esc="mod.menu_label"/>)</span>
                                                            </t>
                                                        </div>
                                                        <div style="font-size:11px;color:#94a3b8;" t-esc="mod.name"/>
                                                    </div>
                                                </div>
                                            </t>
                                            <t t-if="filteredModulesForRoleVisAdd.length===0">
                                                <div style="padding:20px;text-align:center;color:#94a3b8;font-size:13px;">No apps available</div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                        <div class="priv-card">
                            <t t-if="state.roleModuleVisibility.length===0">
                                <div style="padding:24px;text-align:center;color:#94a3b8;font-size:13px;">
                                    <i class="fa fa-th" style="font-size:28px;opacity:0.3;display:block;margin-bottom:8px;"/>
                                    All apps visible for this group. Click <b>Add App</b> to hide app icons for all group members.
                                </div>
                            </t>
                            <t t-if="state.roleModuleVisibility.length>0">
                                <div style="font-size:11px;font-weight:700;color:#dc2626;text-transform:uppercase;letter-spacing:0.5px;padding:8px 0 4px 0;cursor:pointer;display:flex;align-items:center;" t-on-click="()=>this.toggleSection('roleModuleVis')">
                                    <i t-att-class="'fa me-1 '+(isSectionCollapsed('roleModuleVis')?'fa-chevron-right':'fa-chevron-down')" style="font-size:10px;width:14px;"/>
                                    <i class="fa fa-th me-1"/>App Icons
                                    <span class="priv-badge-red ms-2" t-esc="state.roleModuleVisibility.length"/>
                                </div>
                                <t t-if="!isSectionCollapsed('roleModuleVis')">
                                <div class="priv-table-header">
                                    <div class="priv-model-name">Application</div>
                                    <div class="priv-vis-col">App Visible</div>
                                    <div style="width:50px;"/>
                                </div>
                                <t t-foreach="state.roleModuleVisibility" t-as="rmod" t-key="rmod.id">
                                    <div class="vis-row">
                                        <div class="priv-model-name">
                                            <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="rmod.module_shortdesc||rmod.module_id[1]"/>
                                        </div>
                                        <div class="priv-vis-col">
                                            <div class="priv-toggle" t-on-click="()=>this.onRoleModuleVisToggle(rmod.id,rmod.is_visible)" style="justify-content:center;">
                                                <i t-att-class="'fa priv-toggle-icon '+(rmod.is_visible?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:22px;"/>
                                            </div>
                                        </div>
                                        <div style="width:50px;text-align:center;">
                                            <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveRoleModule(rmod.id)"><i class="fa fa-trash-o"/></button>
                                        </div>
                                    </div>
                                </t>
                                </t>
                            </t>
                        </div>

                    </div><!-- /padding -->
                </t>
            </t><!-- /groups tab -->

        </div><!-- /main content -->
        </div><!-- /priv-layout -->

        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <!-- Dependency Prompt Modal                                       -->
        <!-- Shown when Add Module is clicked and the module depends on   -->
        <!-- other modules the user isn't yet configured for. Admin can    -->
        <!-- pick which deps to co-add, preventing cross-module "access    -->
        <!-- denied" errors.                                               -->
        <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
        <t t-if="state.depPrompt.show">
            <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(15,23,42,0.55);z-index:100000;display:flex;align-items:center;justify-content:center;padding:20px;">
                <div style="background:#fff;border-radius:12px;max-width:560px;width:100%;max-height:85vh;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,0.25);overflow:hidden;">
                    <div style="padding:20px 24px 14px 24px;border-bottom:1px solid #e0e4ea;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <i class="fa fa-exclamation-triangle" style="color:#f97316;font-size:22px;"/>
                            <div style="font-size:17px;font-weight:700;color:#1e293b;">Module has dependencies</div>
                        </div>
                        <div style="margin-top:8px;font-size:13px;color:#64748b;line-height:1.5;">
                            <b t-esc="state.depPrompt.moduleName"/> relies on other module(s) for some of its features.
                            Without them, this user may see "access denied" errors when opening certain forms
                            (for example, a Sales record showing linked Payments). Tick the ones to add alongside.
                        </div>
                    </div>
                    <div style="padding:10px 24px;background:#f8f9fc;border-bottom:1px solid #e0e4ea;display:flex;gap:16px;align-items:center;">
                        <button class="priv-btn" t-on-click="()=>this.onDepPromptToggleAll(true)">
                            <i class="fa fa-check-square-o me-1"/>Select all
                        </button>
                        <button class="priv-btn" t-on-click="()=>this.onDepPromptToggleAll(false)">
                            <i class="fa fa-square-o me-1"/>Select none
                        </button>
                        <span style="margin-left:auto;font-size:12px;color:#94a3b8;">
                            <t t-esc="state.depPrompt.missingDeps.length"/> dependency module(s)
                        </span>
                    </div>
                    <div style="overflow-y:auto;flex:1;padding:4px 0;">
                        <t t-foreach="state.depPrompt.missingDeps" t-as="dep" t-key="dep.id">
                            <div class="priv-table-row" style="padding:10px 24px;cursor:pointer;" t-on-click="()=>this.onDepPromptToggle(dep.id)">
                                <div class="priv-model-name">
                                    <div style="font-weight:500;color:#1e293b;" t-esc="dep.shortdesc"/>
                                    <div style="font-size:11px;color:#94a3b8;" t-esc="dep.name"/>
                                </div>
                                <div style="width:90px;text-align:center;">
                                    <i t-att-class="'fa priv-toggle-icon '+(state.depPrompt.selectedDepIds[dep.id]?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:22px;"/>
                                </div>
                            </div>
                        </t>
                    </div>
                    <div style="padding:14px 24px;border-top:1px solid #e0e4ea;background:#f8f9fc;display:flex;gap:10px;justify-content:flex-end;">
                        <button class="priv-discard-btn" t-on-click="onDepPromptCancel">
                            <i class="fa fa-times"/><span>Cancel</span>
                        </button>
                        <button class="priv-btn" t-on-click="onDepPromptSkip" style="font-size:12px;padding:7px 14px;">
                            Add only <t t-esc="state.depPrompt.moduleName"/>
                        </button>
                        <button class="priv-update-btn" t-on-click="onDepPromptConfirm">
                            <i class="fa fa-check"/>
                            <span>Add selected</span>
                        </button>
                    </div>
                </div>
            </div>
        </t>

        </div>
    </t>

    <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
    <!-- ModuleCard sub-template                                        -->
    <!-- Called by the main template via t-call. Receives:              -->
    <!--   mp     Гўв‚¬вЂќ the module.privilege record                         -->
    <!--   isDep  Гўв‚¬вЂќ true if this is a dependency card (collapsed body)  -->
    <!--                                                                 -->
    <!-- Dep cards render as a compact one-liner by default. Click the  -->
    <!-- header to expand and reveal the full toggles / chips / models. -->
    <!-- Non-dep (primary) cards render expanded as before.              -->
    <!-- ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ -->
    <t t-name="user_privilege_manager_apps.ModuleCard">
        <t t-set="showBody" t-value="(!isDep) or isDepCardExpanded(mp.id)"/>

        <div t-att-class="'priv-card' + (isDep ? ' priv-card-dep' : '')">
            <!-- Header row (always visible) -->
            <div class="d-flex align-items-center justify-content-between" style="padding:0;">
                <div class="priv-card-header flex-grow-1"
                     t-on-click="() => isDep ? this.toggleDepCard(mp.id) : this.toggleExpand(mp.id)">
                    <t t-if="isDep">
                        <i t-att-class="'fa me-2 '+(isDepCardExpanded(mp.id)?'fa-chevron-down':'fa-chevron-right')" style="font-size:10px;color:#92400e;width:14px;"/>
                        <i class="fa fa-cube me-2" style="color:#92400e;font-size:12px;"/>
                    </t>
                    <t t-else="">
                        <i t-att-class="'fa me-2 '+(isExpanded(mp.id)?'fa-chevron-down':'fa-chevron-right')" style="font-size:10px;color:#94a3b8;width:14px;"/>
                    </t>
                    <span class="priv-card-title me-2" t-esc="mp.module_shortdesc||mp.module_name"/>
                    <span class="priv-badge" t-esc="(mp.lines||[]).length+' models'"/>
                    <t t-if="isDep">
                        <span style="margin-left:10px;font-size:11px;color:#92400e;font-style:italic;">
                            (dependency of <t t-esc="dependencyParentLabel(mp.id) || 'a primary module'"/>)
                        </span>
                    </t>
                </div>
                <div style="display:flex;gap:6px;padding-right:14px;">
                    <t t-if="!isDep or isDepCardExpanded(mp.id)">
                        <button class="priv-btn priv-btn-green" t-on-click="()=>this.onGrantAll(mp.id)"><i class="fa fa-check me-1"/>Grant All</button>
                        <button class="priv-btn" t-on-click="()=>this.onRevokeAll(mp.id)">Read Only</button>
                    </t>
                    <button class="priv-btn priv-btn-red" t-on-click="()=>this.onRemoveModule(mp.id)" t-att-title="isDep ? 'Remove this dependency' : 'Remove this module'">
                        <i class="fa fa-trash-o"/>
                    </button>
                </div>
            </div>

            <!-- Body (visible for primary cards; only when expanded for dep cards) -->
            <t t-if="showBody">
                <div class="priv-master-row">
                    <div class="priv-toggle" t-on-click="()=>this.onMasterToggle(mp.id,'master_read',mp.master_read)">
                        <i t-att-class="'fa priv-toggle-icon '+(mp.master_read?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')"/>
                        <span t-att-class="mp.master_read?'priv-toggle-label-on':'priv-toggle-label-off'">Read</span>
                    </div>
                    <div class="priv-toggle" t-on-click="()=>this.onMasterToggle(mp.id,'master_create',mp.master_create)">
                        <i t-att-class="'fa priv-toggle-icon '+(mp.master_create?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')"/>
                        <span t-att-class="mp.master_create?'priv-toggle-label-on':'priv-toggle-label-off'">Create</span>
                    </div>
                    <div class="priv-toggle" t-on-click="()=>this.onMasterToggle(mp.id,'master_write',mp.master_write)">
                        <i t-att-class="'fa priv-toggle-icon '+(mp.master_write?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')"/>
                        <span t-att-class="mp.master_write?'priv-toggle-label-on':'priv-toggle-label-off'">Edit</span>
                    </div>
                    <div class="priv-toggle" t-on-click="()=>this.onMasterToggle(mp.id,'master_cancel',mp.master_cancel)">
                        <i t-att-class="'fa priv-toggle-icon '+(mp.master_cancel?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')"/>
                        <span t-att-class="mp.master_cancel?'priv-toggle-label-on':'priv-toggle-label-off'">Cancel</span>
                    </div>
                    <div class="priv-toggle" t-on-click="()=>this.onMasterToggle(mp.id,'master_unlink',mp.master_unlink)">
                        <i t-att-class="'fa priv-toggle-icon '+(mp.master_unlink?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')"/>
                        <span t-att-class="mp.master_unlink?'priv-toggle-label-on':'priv-toggle-label-off'">Delete</span>
                    </div>
                </div>

                <!-- Access Level section Гўв‚¬вЂќ compact summary by default, expand on click (Option C) -->
                <t t-set="accessGroups" t-value="state.moduleAccessGroups[mp.id] || []"/>
                <t t-if="accessGroups.length > 0">
                    <t t-set="summary" t-value="accessLevelSummary(mp.id)"/>
                    <div style="background:#f0f7ff;border-top:1px solid #dbeafe;">
                        <!-- Compact summary row (always visible, click to expand) -->
                        <div style="padding:8px 18px;display:flex;align-items:center;gap:8px;cursor:pointer;" t-on-click="()=>this.toggleAccessLevelSection(mp.id)">
                            <i t-att-class="'fa '+(isAccessLevelExpanded(mp.id)?'fa-chevron-down':'fa-chevron-right')" style="font-size:10px;color:#1d4ed8;width:14px;"/>
                            <i class="fa fa-users" style="color:#1d4ed8;font-size:12px;"/>
                            <span style="font-size:11px;font-weight:700;color:#1d4ed8;text-transform:uppercase;letter-spacing:0.5px;">Access Level</span>
                            <span t-att-style="'font-size:12px;margin-left:8px;'+(summary.empty?'color:#ef4444;font-style:italic;':'color:#1e40af;')" t-esc="summary.text"/>
                            <span style="margin-left:auto;font-size:11px;color:#64748b;" t-esc="'(' + summary.total + ' available)'"/>
                        </div>
                        <!-- Expanded chip grid -->
                        <t t-if="isAccessLevelExpanded(mp.id)">
                            <div style="padding:4px 18px 12px 18px;">
                                <div style="font-size:11px;color:#64748b;font-style:italic;margin-bottom:8px;">
                                    Tick access levels to unlock menus &amp; features for this user.
                                    <button class="priv-btn priv-btn-purple" style="font-size:11px;margin-left:10px;" t-on-click="()=>this.onGrantAllGroups(mp.id)">
                                        <i class="fa fa-check-double me-1"/>Grant All
                                    </button>
                                </div>
                                <div style="display:flex;flex-wrap:wrap;gap:10px;">
                                    <t t-foreach="accessGroups" t-as="grp" t-key="grp.id">
                                        <label t-att-class="'priv-access-group'+(grp.is_member?' priv-access-group-on':'')" t-att-title="grp.comment || grp.name">
                                            <input type="checkbox"
                                                   t-att-checked="grp.is_member"
                                                   t-on-change="()=>this.onAccessGroupToggle(mp.id, grp.id)"/>
                                            <span t-esc="grp.short_name || grp.name"/>
                                            <t t-if="grp.source_label">
                                                <span style="font-size:10px;color:#7c3aed;font-weight:400;margin-left:4px;">(from <t t-esc="grp.source_label"/>)</span>
                                            </t>
                                        </label>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </t>

                <!-- Per-model CRUD table -->
                <t t-if="isExpanded(mp.id)">
                    <div class="priv-table-header">
                        <div class="priv-model-name">Model</div>
                        <div class="priv-perm-col">Read</div><div class="priv-perm-col">Create</div>
                        <div class="priv-perm-col">Edit</div><div class="priv-perm-col">Cancel</div><div class="priv-perm-col">Delete</div>
                    </div>
                    <t t-foreach="mp.lines||[]" t-as="line" t-key="line.id">
                        <div class="priv-table-row">
                            <div class="priv-model-name">
                                <div style="font-weight:500;color:#1e293b;" class="text-truncate" t-esc="line.model_id[1]"/>
                                <div style="font-size:11px;color:#94a3b8;" t-esc="line.model_name"/>
                            </div>
                            <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_read?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onLineToggle(line.id,'perm_read',line.perm_read)"/></div>
                            <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_create?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onLineToggle(line.id,'perm_create',line.perm_create)"/></div>
                            <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_write?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onLineToggle(line.id,'perm_write',line.perm_write)"/></div>
                            <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_cancel?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onLineToggle(line.id,'perm_cancel',line.perm_cancel)"/></div>
                            <div class="priv-perm-col"><i t-att-class="'fa '+(line.perm_unlink?'fa-toggle-on priv-toggle-on':'fa-toggle-off priv-toggle-off')" style="font-size:18px;cursor:pointer;" t-on-click="()=>this.onLineToggle(line.id,'perm_unlink',line.perm_unlink)"/></div>
                        </div>
                    </t>
                </t>
            </t>
        </div>
    </t>

</templates>
