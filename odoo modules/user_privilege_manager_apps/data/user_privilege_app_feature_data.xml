        <field name="description">Show the Sales sub-tile in the Journal Entries popup.</field>
        <field name="parent_id" ref="feature_home_tile_journal_entries"/>
        <field name="sequence">230</field>
    </record>
    <record id="feature_acc_journals_purchases" model="app.feature.app">
        <field name="feature_key">accounting.journals.purchases</field>
        <field name="name">Journals - Purchases</field>
        <field name="description">Show the Purchases sub-tile in the Journal Entries popup.</field>
        <field name="parent_id" ref="feature_home_tile_journal_entries"/>
