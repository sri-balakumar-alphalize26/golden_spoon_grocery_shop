<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Form View -->
    <record id="app_banner_form_view" model="ir.ui.view">
        <field name="name">app.banner.form</field>
        <field name="model">app.banner</field>
        <field name="arch" type="xml">
            <form string="Banner">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="sequence"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="image" widget="image" options="{'size': [800, 400]}"/>
                            <field name="image_filename" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- List View -->
    <record id="app_banner_list_view" model="ir.ui.view">
        <field name="name">app.banner.list</field>
        <field name="model">app.banner</field>
        <field name="arch" type="xml">
            <list string="Banners" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="image" widget="image" options="{'size': [100, 50]}"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Action -->
    <record id="app_banner_action" model="ir.actions.act_window">
        <field name="name">App Banners</field>
        <field name="res_model">app.banner</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="app_banner_menu_root" name="App Banners" action="app_banner_action" sequence="100"/>

</odoo>
