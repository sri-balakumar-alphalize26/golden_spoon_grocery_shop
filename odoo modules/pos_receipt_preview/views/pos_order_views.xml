<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add a "Preview Receipt" button to the pos.order form header. This is
         the backend equivalent of the app's order-detail Preview button:
         it opens the paper-size popup, which then renders the receipt. -->
    <record id="view_pos_pos_form_receipt_preview" model="ir.ui.view">
        <field name="name">pos.order.form.receipt.preview</field>
        <field name="model">pos.order</field>
        <field name="inherit_id" ref="point_of_sale.view_pos_pos_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_receipt_preview"
                        type="object"
                        string="Preview Receipt"
                        class="btn-primary"
                        icon="fa-eye"/>
            </xpath>
        </field>
    </record>

</odoo>
