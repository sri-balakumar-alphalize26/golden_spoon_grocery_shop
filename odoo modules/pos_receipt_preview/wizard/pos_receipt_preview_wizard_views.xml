<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- The "choose receipt size" popup. Opened as target='new' from the
         pos.order form button, so it appears as a modal dialog. Picking a
         size + Preview renders the receipt view-only at that width. -->
    <record id="pos_receipt_preview_wizard_form" model="ir.ui.view">
        <field name="name">pos.receipt.preview.wizard.form</field>
        <field name="model">pos.receipt.preview.wizard</field>
        <field name="arch" type="xml">
            <form string="Choose Receipt Size">
                <field name="order_id" invisible="1"/>
                <group>
                    <field name="paper_size" widget="radio"/>
                </group>
                <footer>
                    <button name="action_preview" string="Preview" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
