<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="device_registry_view_list" model="ir.ui.view">
        <field name="name">device.registry.list</field>
        <field name="model">device.registry</field>
        <field name="arch" type="xml">
            <list string="Device Registry">
                <field name="device_name"/>
                <field name="mac_address" string="Device ID"/>
                <field name="database_name"/>
                <field name="base_url"/>
                <field name="status"
                       decoration-warning="status == 'pre_registered'"
                       decoration-success="status == 'active'"
                       decoration-danger="status == 'blocked'"/>
                <field name="last_login"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="device_registry_view_form" model="ir.ui.view">
        <field name="name">device.registry.form</field>
        <field name="model">device.registry</field>
        <field name="arch" type="xml">
            <form string="Device Registry">
                <sheet>
                    <group>
                        <group string="Auto-filled by App Scan">
                            <field name="device_name"
                                   string="Device Name"
                                   placeholder="Auto-filled by app scan, or type manually"/>
                            <field name="mac_address"
                                   string="Device ID"
                                   placeholder="Auto-filled by app scan, or type manually"/>
                            <field name="status"/>
                        </group>
                        <group string="Connection Details">
                            <field name="device_id"
                                   readonly="1"
                                   placeholder="Filled when app activates"/>
                            <field name="base_url"
                                   readonly="1"
                                   placeholder="Filled when app activates"/>
                            <field name="database_name"
                                   readonly="1"
                                   placeholder="Filled when app activates"/>
                            <field name="last_login" readonly="1"/>
                        </group>
                    </group>

                    <!-- QR Code — auto-generated on New, includes record ID -->
                    <group string="Scan this QR from the App">
                        <div style="text-align:center; padding: 16px;">
                            <p style="color:#555; margin-bottom:14px; line-height:1.7;">
                                On the tablet app — tap <b>Configure Device</b>
                                → <b>Scan QR</b> → point camera at this QR.<br/>
                                Device ID and Name are filled automatically.<br/>
                                <span style="color:#888; font-size:12px;">
                                    Reload this page after scanning to see the registered device.
                                </span>
                            </p>
                            <field name="registration_qr_image" widget="image"
                                   options="{'size': [220, 220]}" nolabel="1"
                                   style="border:1px solid #eee; border-radius:8px;"/>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="device_registry_view_search" model="ir.ui.view">
        <field name="name">device.registry.search</field>
        <field name="model">device.registry</field>
        <field name="arch" type="xml">
            <search string="Search Devices">
                <field name="mac_address" string="Device ID"/>
                <field name="device_name"/>
                <field name="database_name"/>
                <filter string="Pre-Registered" name="pre_registered"
                        domain="[('status','=','pre_registered')]"/>
                <filter string="Active" name="active"
                        domain="[('status','=','active')]"/>
                <filter string="Blocked" name="blocked"
                        domain="[('status','=','blocked')]"/>
                <separator/>
                <filter string="Group by Status" name="group_status"
                        context="{'group_by': 'status'}"/>
                <filter string="Group by Database" name="group_db"
                        context="{'group_by': 'database_name'}"/>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="device_registry_action" model="ir.actions.act_window">
        <field name="name">Device Registry</field>
        <field name="res_model">device.registry</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="device_registry_view_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No devices registered yet.
            </p>
            <p>
                Click <b>New</b> — a QR code appears automatically.
                Show it to the tablet.
                On the app tap <b>Configure Device</b> → <b>Scan QR</b>.
                Both Device ID and Device Name are filled automatically from the tablet.
                Reload this page after scanning to see them.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="device_registry_menu_root"
              name="Device Registry"
              sequence="90"
              groups="base.group_system"/>

    <menuitem id="device_registry_menu_devices"
              name="Devices"
              parent="device_registry_menu_root"
              action="device_registry_action"
              sequence="10"
              groups="base.group_system"/>

</odoo>
