<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== MENU PRIVILEGE TREE ==================== -->
    <record id="view_menu_privilege_list" model="ir.ui.view">
        <field name="name">menu.privilege.list</field>
        <field name="model">menu.privilege</field>
        <field name="arch" type="xml">
            <list string="Menu Privileges" editable="bottom">
                <field name="user_id"/>
                <field name="menu_id"/>
                <field name="menu_full_name"/>
                <field name="is_visible" widget="boolean_toggle"/>
                <field name="company_id" optional="hide" groups="base.group_multi_company"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- ==================== MENU PRIVILEGE FORM ==================== -->
    <record id="view_menu_privilege_form" model="ir.ui.view">
        <field name="name">menu.privilege.form</field>
        <field name="model">menu.privilege</field>
        <field name="arch" type="xml">
            <form string="Menu Privilege">
                <sheet>
                    <group>
                        <group string="Configuration">
                            <field name="user_id"/>
                            <field name="menu_id"/>
                            <field name="menu_full_name" readonly="1"/>
                        </group>
                        <group string="Visibility">
                            <field name="is_visible" widget="boolean_toggle"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="active"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== MENU PRIVILEGE SEARCH ==================== -->
    <record id="view_menu_privilege_search" model="ir.ui.view">
        <field name="name">menu.privilege.search</field>
        <field name="model">menu.privilege</field>
        <field name="arch" type="xml">
            <search string="Search Menu Privileges">
                <field name="user_id"/>
                <field name="menu_id"/>
                <field name="menu_full_name"/>
                <separator/>
                <filter name="filter_visible" string="Visible" domain="[('is_visible', '=', True)]"/>
                <filter name="filter_hidden" string="Hidden" domain="[('is_visible', '=', False)]"/>
                <separator/>
                <filter name="group_user" string="User" context="{'group_by': 'user_id'}"/>
                <filter name="group_menu" string="Menu" context="{'group_by': 'menu_id'}"/>
            </search>
        </field>
    </record>

    <!-- ==================== MENU PRIVILEGE ACTION ==================== -->
    <record id="action_menu_privilege" model="ir.actions.act_window">
        <field name="name">Menu Visibility</field>
        <field name="res_model">menu.privilege</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_menu_privilege_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Control menu visibility per user
            </p>
            <p>
                Add menu items here and toggle visibility to show/hide
                specific menus for individual users.
                <br/>
                If no record exists for a menu, it remains visible (standard behavior).
            </p>
        </field>
    </record>

    <!-- ==================== Bulk Set Visibility Button (header in list view) ==================== -->
    <record id="view_menu_privilege_list_bulk_button" model="ir.ui.view">
        <field name="name">menu.privilege.list.bulk.button</field>
        <field name="model">menu.privilege</field>
        <field name="inherit_id" ref="view_menu_privilege_list"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <header>
                    <button name="%(action_menu_privilege_bulk_wizard)d"
                            string="Set Menu Visibility" type="action"
                            class="btn-primary" icon="fa-plus"/>
                </header>
            </xpath>
        </field>
    </record>

</odoo>
